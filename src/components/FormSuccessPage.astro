---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/t';
import { pathContacts, pathHome } from '../i18n/paths';
import type { Lang } from '../i18n/types';
import { graphLd, webPageJsonLd } from '../lib/seo';

type Props = { lang: Lang; variant: 'contact' | 'callback' };

const { lang, variant } = Astro.props;
const titleKey = variant === 'contact' ? 'meta.docContactSuccess' : 'meta.docCallbackSuccess';
const title = `${t(lang, titleKey)} | ${t(lang, 'meta.brand')}`;
const heading = variant === 'contact' ? t(lang, 'success.contactTitle') : t(lang, 'success.callbackTitle');
const body = variant === 'contact' ? t(lang, 'success.contactBody') : t(lang, 'success.callbackBody');
const origin = Astro.site?.origin ?? Astro.url.origin;
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description: body,
    lang,
  }),
);
---

<Layout lang={lang} title={title} description={body} jsonLd={jsonLd} noindex>
  <section
    class="mx-auto max-w-xl px-[max(1rem,env(safe-area-inset-left,0px))] py-10 pe-[max(1rem,env(safe-area-inset-right,0px))] text-center md:py-14"
  >
    <h1 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-wide text-gradient-neon mb-6">
      {heading}
    </h1>
    <p class="text-stone-400 leading-relaxed text-base">{body}</p>
    <div class="flex flex-wrap gap-4 justify-center mt-10">
      <a href={pathHome(lang)} class="btn-neon-primary min-h-12 inline-flex items-center touch-manipulation">
        {t(lang, 'success.backHome')}
      </a>
      <a href={pathContacts(lang)} class="btn-neon-ghost min-h-12 inline-flex items-center touch-manipulation">
        {t(lang, 'success.backContacts')}
      </a>
    </div>
  </section>
</Layout>
