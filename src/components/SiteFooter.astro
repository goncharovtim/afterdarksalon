---
import { contact } from '../data/site';
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';
import { pathBook } from '../i18n/paths';
import GoogleRatingBanner from './GoogleRatingBanner.astro';

type Props = { lang: Lang };

const { lang } = Astro.props;
---

<footer
  class="relative z-10 mt-12 sm:mt-16 border-t border-cyan-500/20 bg-abyss/90 text-stone-400 shadow-[0_-12px_40px_rgba(0,0,0,0.35)]"
>
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-fuchsia-500/50 to-transparent" />
  <div
    class="max-w-7xl mx-auto px-[max(1rem,env(safe-area-inset-left,0px))] py-10 pe-[max(1rem,env(safe-area-inset-right,0px))] sm:py-12"
  >
    <div class="mb-6 sm:mb-8 flex justify-center">
      <GoogleRatingBanner lang={lang} variant="footer" />
    </div>
    <div class="mx-auto grid max-w-2xl justify-items-center gap-10 text-center sm:max-w-none sm:grid-cols-2 sm:gap-14 md:max-w-3xl">
      <div>
        <h2 class="font-display text-xs font-bold uppercase tracking-[0.25em] text-cyan-400 mb-4">
          {t(lang, 'meta.brand')}
        </h2>
        <p class="leading-relaxed text-sm">
          {t(lang, 'footer.address')}{' '}
          <a
            href={contact.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-fuchsia-400 hover:text-fuchsia-300 underline-offset-2"
          >
            {contact.addressLine}
          </a>
          <br />
          {t(lang, 'footer.tel')}{' '}
          <a href={`tel:${contact.phoneTel}`} class="text-cyan-400 hover:text-cyan-300">
            {contact.phoneDisplay}
          </a>
          <br />
          {t(lang, 'footer.email')}{' '}
          <a href={`mailto:${contact.email}`} class="text-cyan-400/90 hover:text-cyan-300 break-all">
            {contact.email}
          </a>
        </p>
      </div>
      <div class="flex flex-col items-center">
        <h3 class="font-display text-xs font-bold uppercase tracking-[0.2em] text-fuchsia-400/90 mb-3">
          {t(lang, 'footer.nightAccess')}
        </h3>
        <p class="text-sm text-stone-500 leading-relaxed">
          {t(lang, 'footer.nightAccessBody')}
        </p>
        <a href={pathBook(lang)} class="btn-neon-ghost mt-4 inline-flex min-h-11 justify-center touch-manipulation px-6">
          {t(lang, 'footer.reserveSlot')}
        </a>
      </div>
    </div>
    <div
      class="mt-12 pt-8 border-t border-white/5 text-center font-display text-[10px] uppercase tracking-widest text-stone-600"
    >
      {t(lang, 'footer.copyright')}
    </div>
  </div>
</footer>
