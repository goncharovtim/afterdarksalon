---
import { featuredMasseuses, massageGrid } from '../data/site';
import { upcomingNightShifts, nightSlots } from '../lib/nights';
import type { Lang } from '../i18n/types';
import { t, tArr } from '../i18n/t';
import { massageTitle } from '../i18n/massages';

type Props = {
  lang: Lang;
  defaultMasseuseSlug?: string;
  compact?: boolean;
};

const { lang, defaultMasseuseSlug = '', compact = false } = Astro.props;
const locale = lang === 'cs' ? 'cs-CZ' : 'en-GB';
const nights = upcomingNightShifts(16, locale);
const demoTpl = t(lang, 'book.demoStatus');
const masseusePickerJson = JSON.stringify(
  featuredMasseuses.map((m) => ({ slug: m.slug, name: m.name, image: m.image })),
);
const selectHostLabel = t(lang, 'book.selectHost');
const nightsJson = JSON.stringify(nights);
const calendarWeekdaysJson = JSON.stringify(tArr(lang, 'book.calendarWeekdays'));
const calPickDate = t(lang, 'book.pickDate');
const calNightSuffix = t(lang, 'book.nightShiftSuffix');
const calPrev = t(lang, 'book.calendarPrev');
const calNext = t(lang, 'book.calendarNext');
const calEmpty = t(lang, 'book.calendarEmptyMonth');
const calLegend = t(lang, 'book.calendarLegend');
const calPickTime = t(lang, 'book.pickTime');
const nightSlotsJson = JSON.stringify([...nightSlots]);
---

<form
  id="booking-form"
  class:list={[
    'card-cyber neon-border space-y-6',
    compact ? 'p-4 sm:p-5 md:p-6' : 'p-4 sm:p-6 md:p-8',
  ]}
  data-default-masseuse={defaultMasseuseSlug}
>
  <div class:list={['flex flex-wrap items-end justify-between gap-4', compact && 'hidden']}>
    <div>
      <h2 class="font-display text-lg md:text-xl font-bold uppercase tracking-[0.15em] text-gradient-neon">
        {t(lang, 'book.nightReservation')}
      </h2>
      <p class="mt-1 text-sm text-stone-400">
        {t(lang, 'book.nightSub')}
      </p>
    </div>
    <span
      class="inline-flex items-center gap-2 rounded border border-amber-500/40 bg-amber-500/10 px-3 py-1 font-display text-[10px] font-bold uppercase tracking-wider text-amber-300"
    >
      <span class="size-1.5 animate-pulse rounded-full bg-amber-400 shadow-[0_0_8px_#ff9e00]" />
      {t(lang, 'book.liveBadge')}
    </span>
  </div>
  {
    compact && (
      <h2 class="font-display text-base font-bold uppercase tracking-[0.15em] text-gradient-neon">
        {t(lang, 'book.quickReserve')}
      </h2>
    )
  }

  <div class="flex flex-col gap-5 md:flex-row md:gap-5">
    <div class="flex min-w-0 flex-1 flex-col gap-2">
      <span
        class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90"
        id="book-masseuse-label"
      >
        {t(lang, 'book.host')}
      </span>
      <select
        name="masseuse"
        id="book-masseuse"
        class="sr-only"
        tabindex="-1"
        aria-hidden="true"
        required
      >
        <option value="">{selectHostLabel}</option>
        {featuredMasseuses.map((m) => (
          <option value={m.slug} selected={m.slug === defaultMasseuseSlug}>
            {m.name}
          </option>
        ))}
      </select>
      <div id="book-masseuse-picker" class="relative z-20 w-full min-w-0"></div>
    </div>

    <label class="flex min-w-0 flex-1 flex-col gap-2">
      <span class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90">
        {t(lang, 'book.service')}
      </span>
      <select
        name="service"
        id="book-service"
        class="box-border min-h-16 w-full rounded-lg border border-cyan-500/30 bg-black/50 px-4 py-2.5 text-sm leading-normal text-stone-100 outline-none focus:border-fuchsia-500 focus:ring-1 focus:ring-fuchsia-500"
        required
      >
        <option value="">{t(lang, 'book.selectRitual')}</option>
        {massageGrid.map((s) => (
          <option value={s.slug}>{massageTitle(lang, s.slug)}</option>
        ))}
      </select>
    </label>
  </div>

  <div class="flex flex-col gap-5 md:flex-row md:gap-5 md:items-stretch md:min-h-0">
    <div class="flex min-w-0 flex-1 flex-col gap-2 md:min-h-0">
      <div class="flex flex-wrap items-end justify-between gap-2 shrink-0">
        <span
          class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90"
          id="book-night-calendar-label"
        >
          {t(lang, 'book.nightDate')}
        </span>
        <span class="font-display text-[9px] uppercase tracking-wider text-stone-600">{calLegend}</span>
      </div>
      <select name="date" id="book-date" class="sr-only" tabindex="-1" aria-hidden="true" required>
        <option value="">{calPickDate}</option>
        {nights.map((n) => (
          <option value={n.value}>
            {n.label} {calNightSuffix}
          </option>
        ))}
      </select>
      <div
        id="book-night-calendar-root"
        class="relative z-10 w-full min-w-0 md:flex md:min-h-0 md:flex-1 md:flex-col"
        data-cal-compact="true"
        role="group"
        aria-labelledby="book-night-calendar-label"
      >
      </div>
    </div>

    <div class="flex min-w-0 flex-1 flex-col gap-2 md:min-h-0">
      <span
        class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90 shrink-0"
        id="book-time-grid-label"
      >
        {t(lang, 'book.arrival')}
      </span>
      <select name="time" id="book-time" class="sr-only" tabindex="-1" aria-hidden="true" required>
        <option value="">{t(lang, 'book.time')}</option>
        {nightSlots.map((time) => (
          <option value={time}>{time}</option>
        ))}
      </select>
      <div
        id="book-time-grid-root"
        class="relative z-10 w-full min-w-0 md:flex md:min-h-0 md:flex-1 md:flex-col"
        role="group"
        aria-labelledby="book-time-grid-label"
      >
      </div>
    </div>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    <label class="block space-y-2 md:col-span-1">
      <span class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90">
        {t(lang, 'book.yourName')}
      </span>
      <input
        type="text"
        name="name"
        autocomplete="name"
        class="min-h-12 w-full rounded-lg border border-cyan-500/30 bg-black/50 px-4 py-3 text-base text-stone-100 outline-none focus:border-fuchsia-500 sm:text-sm"
        required
      />
    </label>
    <label class="block space-y-2 md:col-span-1">
      <span class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90">
        {t(lang, 'book.phone')}
      </span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        class="min-h-12 w-full rounded-lg border border-cyan-500/30 bg-black/50 px-4 py-3 text-base text-stone-100 outline-none focus:border-fuchsia-500 sm:text-sm"
        required
      />
    </label>
    <label class="block space-y-2 md:col-span-2">
      <span class="font-display text-[10px] font-bold uppercase tracking-widest text-cyan-400/90">
        {t(lang, 'book.note')}
      </span>
      <textarea
        name="note"
        rows={3}
        class="w-full rounded-lg border border-cyan-500/30 bg-black/50 px-4 py-3 text-sm text-stone-100 outline-none focus:border-fuchsia-500 resize-y min-h-[88px]"
        placeholder={t(lang, 'book.notePh')}
      />
    </label>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end sm:gap-4">
    <button type="submit" class="btn-neon-primary order-1 min-h-12 w-full touch-manipulation sm:w-auto sm:shrink-0">
      {t(lang, 'book.submit')}
    </button>
    <p id="booking-status" class="order-2 hidden text-sm text-cyan-300" role="status"></p>
  </div>
</form>

<script
  is:inline
  define:vars={{
    demoTpl,
    masseusePickerJson,
    selectHostLabel,
    nightsJson,
    nightSlotsJson,
    locale,
    calendarWeekdaysJson,
    calPickDate,
    calPickTime,
    calNightSuffix,
    calPrev,
    calNext,
    calEmpty,
  }}
>
  const MASSEUSES = JSON.parse(masseusePickerJson);

  function mountMasseusePicker() {
    var root = document.getElementById('book-masseuse-picker');
    var hidden = document.getElementById('book-masseuse');
    if (!root || !hidden || !(hidden instanceof HTMLSelectElement)) return;

    var ph = selectHostLabel;
    var triggerId = 'book-masseuse-trigger';
    var listId = 'book-masseuse-listbox';

    function bySlug(slug) {
      return MASSEUSES.find(function (m) {
        return m.slug === slug;
      });
    }

    function setNative(val) {
      hidden.value = val;
      hidden.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function setChevronOpen(open) {
      var chev = trigger.querySelector('[data-chev]');
      if (chev) chev.classList.toggle('rotate-180', open);
    }

    function closeList() {
      list.hidden = true;
      trigger.setAttribute('aria-expanded', 'false');
      setChevronOpen(false);
    }

    function openList() {
      list.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      setChevronOpen(true);
    }

    function syncTrigger() {
      var v = hidden.value;
      var m = bySlug(v);
      var imgWrap = trigger.querySelector('[data-thumb-wrap]');
      var img = trigger.querySelector('[data-thumb]');
      var label = trigger.querySelector('[data-label]');
      var chev = trigger.querySelector('[data-chev]');
      if (!imgWrap || !img || !label || !chev) return;
      if (m) {
        imgWrap.classList.remove('hidden');
        img.src = m.image;
        img.alt = '';
        label.textContent = m.name;
      } else {
        imgWrap.classList.add('hidden');
        img.removeAttribute('src');
        label.textContent = ph;
      }
      Array.prototype.forEach.call(list.querySelectorAll('[role="option"]'), function (opt) {
        var sel = opt.getAttribute('data-slug') === v;
        opt.setAttribute('aria-selected', sel ? 'true' : 'false');
        opt.classList.toggle('bg-cyan-500/15', sel);
        opt.classList.toggle('border-cyan-500/30', sel);
      });
    }

    root.innerHTML =
      '' +
      '<button type="button" id="' +
      triggerId +
      '" class="book-ms-trigger flex w-full min-h-16 items-center gap-2 rounded-lg border border-cyan-500/30 bg-black/50 py-2.5 ps-3 pe-2 text-left text-sm text-stone-100 outline-none hover:border-cyan-500/45 focus-visible:border-fuchsia-500 focus-visible:ring-1 focus-visible:ring-fuchsia-500 touch-manipulation sm:gap-3 sm:pe-2.5" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="book-masseuse-label ' +
      triggerId +
      '" aria-controls="' +
      listId +
      '">' +
      '<span data-thumb-wrap class="relative hidden size-11 shrink-0 overflow-hidden rounded-lg border border-white/15 bg-black/40">' +
      '<img data-thumb alt="" class="size-full object-cover object-top" width="44" height="44" loading="lazy" decoding="async" />' +
      '</span>' +
      '<span data-label class="min-w-0 flex-1 truncate pe-1 font-medium text-stone-200">' +
      ph +
      '</span>' +
      '<span data-chev class="pointer-events-none flex size-10 shrink-0 items-center justify-center text-cyan-400 transition-transform duration-200 ease-out" aria-hidden="true">' +
      '<svg class="size-[1.35rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>' +
      '</span>' +
      '</button>' +
      '<ul id="' +
      listId +
      '" role="listbox" tabindex="-1" hidden class="scrollbar-cyber absolute left-0 right-0 top-full z-30 mt-1 max-h-[min(22rem,calc(100vh-8rem))] overflow-y-auto overscroll-contain rounded-xl border border-cyan-500/25 bg-[#0a0a0c]/98 py-1 pe-0.5 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.9)] backdrop-blur-xl ring-1 ring-white/[0.06] [scrollbar-gutter:stable]"></ul>';

    var trigger = document.getElementById(triggerId);
    var list = document.getElementById(listId);
    if (!trigger || !list) return;

    var optHtml = MASSEUSES.map(function (m) {
      return (
        '<li role="option" tabindex="-1" data-slug="' +
        m.slug +
        '" class="flex cursor-pointer items-center gap-3 px-2 py-2 text-sm text-stone-200 transition-colors hover:bg-white/[0.05] focus:bg-white/[0.06] focus:outline-none border border-transparent rounded-lg mx-1 touch-manipulation">' +
        '<span class="size-11 shrink-0 overflow-hidden rounded-lg border border-white/12 bg-black/50"><img src="' +
        m.image +
        '" alt="" class="size-full object-cover object-top" width="44" height="44" loading="lazy"/></span>' +
        '<span class="min-w-0 flex-1 font-medium">' +
        m.name +
        '</span>' +
        '</li>'
      );
    }).join('');
    list.innerHTML = optHtml;

    syncTrigger();

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      if (list.hidden) openList();
      else closeList();
    });

    list.addEventListener('click', function (e) {
      var li = e.target && e.target.closest && e.target.closest('[role="option"]');
      if (!li || !list.contains(li)) return;
      var slug = li.getAttribute('data-slug') || '';
      setNative(slug);
      closeList();
      trigger.focus();
    });

    document.addEventListener('click', function (e) {
      if (!root.contains(e.target)) closeList();
    });

    document.addEventListener('keydown', function (e) {
      if (list.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeList();
        trigger.focus();
      }
    });

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        if (list.hidden) openList();
        else closeList();
      }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        if (list.hidden) openList();
        var opts = Array.prototype.slice.call(list.querySelectorAll('[role="option"]'));
        if (!opts.length) return;
        var i;
        if (e.key === 'ArrowDown') {
          i = opts.findIndex(function (o) {
            return o === document.activeElement;
          });
          if (i < 0) i = -1;
          var next = opts[Math.min(opts.length - 1, i + 1)];
          next.focus();
        } else {
          i = opts.findIndex(function (o) {
            return o === document.activeElement;
          });
          if (i < 0) i = 1;
          var prev = opts[Math.max(0, i - 1)];
          prev.focus();
        }
      }
    });

    Array.prototype.forEach.call(list.querySelectorAll('[role="option"]'), function (opt) {
      opt.addEventListener('keydown', function (e) {
        var opts = Array.prototype.slice.call(list.querySelectorAll('[role="option"]'));
        var i = opts.indexOf(opt);
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          var slug = opt.getAttribute('data-slug') || '';
          setNative(slug);
          closeList();
          trigger.focus();
        }
        if (e.key === 'Escape') {
          e.preventDefault();
          closeList();
          trigger.focus();
        }
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (i < opts.length - 1) opts[i + 1].focus();
        }
        if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (i > 0) opts[i - 1].focus();
          else trigger.focus();
        }
      });
    });
  }

  function mountNightCalendar() {
    var nights = [];
    try {
      nights = JSON.parse(nightsJson);
    } catch (e) {
      nights = [];
    }
    var labelByValue = {};
    var valuesSet = {};
    for (var i = 0; i < nights.length; i++) {
      labelByValue[nights[i].value] = nights[i].label;
      valuesSet[nights[i].value] = true;
    }
    var select = document.getElementById('book-date');
    var root = document.getElementById('book-night-calendar-root');
    if (!select || !root || !(select instanceof HTMLSelectElement)) return;

    var weekdays = [];
    try {
      weekdays = JSON.parse(calendarWeekdaysJson);
    } catch (e) {
      weekdays = ['Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa', 'Su'];
    }

    function isoFromDate(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var day = String(d.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + day;
    }

    function parseIso(iso) {
      var p = String(iso).split('-');
      if (p.length !== 3) return new Date();
      return new Date(parseInt(p[0], 10), parseInt(p[1], 10) - 1, parseInt(p[2], 10), 12, 0, 0, 0);
    }

    var view = new Date();
    view.setDate(1);
    view.setHours(12, 0, 0, 0);
    if (nights[0] && nights[0].value) {
      var pv = nights[0].value.split('-');
      if (pv.length === 3) {
        view.setFullYear(parseInt(pv[0], 10), parseInt(pv[1], 10) - 1, 1);
      }
    }

    var today = new Date();
    today.setHours(12, 0, 0, 0);
    var todayIso = isoFromDate(today);

    function minMaxMonths() {
      if (!nights.length) {
        return { min: view, max: view };
      }
      return {
        min: parseIso(nights[0].value),
        max: parseIso(nights[nights.length - 1].value),
      };
    }

    function monthStart(d) {
      return new Date(d.getFullYear(), d.getMonth(), 1, 12, 0, 0, 0);
    }

    function canGoPrev() {
      var mm = minMaxMonths();
      var prev = new Date(view.getFullYear(), view.getMonth() - 1, 1, 12, 0, 0, 0);
      return monthStart(prev) >= monthStart(mm.min);
    }

    function canGoNext() {
      var mm = minMaxMonths();
      var next = new Date(view.getFullYear(), view.getMonth() + 1, 1, 12, 0, 0, 0);
      return monthStart(next) <= monthStart(mm.max);
    }

    function selectedLabel() {
      var v = select.value;
      if (!v) return calPickDate;
      var lb = labelByValue[v];
      if (!lb) return calPickDate;
      return lb + ' ' + calNightSuffix;
    }

    function render() {
      var compact = root.getAttribute('data-cal-compact') === 'true';
      var cardPad = compact ? 'p-2 sm:p-3' : 'p-3 sm:p-4';
      var headMb = compact ? 'mb-2 pb-2' : 'mb-3 pb-3';
      var summaryText = compact ? 'text-xs' : 'text-sm';
      var navSz = compact ? 'size-9' : 'size-10';
      var navSvg = compact ? 'size-4' : 'size-5';
      var monthTitleMb = compact ? 'mb-1.5' : 'mb-2';
      var monthTitleText = compact ? 'text-[10px] tracking-[0.16em]' : 'text-xs tracking-[0.2em]';
      var wkRowMb = compact ? 'mb-0.5' : 'mb-1';
      var wkCell = compact
        ? 'py-0.5 font-display text-[8px] font-bold uppercase tracking-wider text-stone-500'
        : 'py-1 font-display text-[9px] font-bold uppercase tracking-wider text-stone-500';
      var gridGap = compact ? 'gap-1' : 'gap-1.5';
      var dayBase =
        'relative flex flex-col items-center justify-center rounded-lg border font-semibold tabular-nums transition-all touch-manipulation ' +
        (compact
          ? 'min-h-[2.25rem] text-xs'
          : 'min-h-[2.75rem] text-sm sm:min-h-[3rem]');

      var y = view.getFullYear();
      var m = view.getMonth();
      var monthTitle = view.toLocaleDateString(locale, { month: 'long', year: 'numeric' });
      var cp = canGoPrev();
      var cn = canGoNext();
      var selected = select.value;

      var first = new Date(y, m, 1, 12, 0, 0, 0);
      var startPad = (first.getDay() + 6) % 7;
      var dim = new Date(y, m + 1, 0).getDate();

      var hasAny = false;
      for (var di = 1; di <= dim; di++) {
        var iso = isoFromDate(new Date(y, m, di, 12, 0, 0, 0));
        if (valuesSet[iso]) {
          hasAny = true;
          break;
        }
      }

      var head =
        '<div class="flex min-h-0 flex-1 flex-col rounded-xl border border-cyan-500/25 bg-black/45 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] ' +
        cardPad +
        '">' +
        '<div class="flex shrink-0 flex-wrap items-center justify-between gap-2 border-b border-white/[0.06] ' +
        headMb +
        '">' +
        '<p class="min-w-0 flex-1 font-display font-semibold uppercase tracking-[0.12em] text-cyan-200/95 ' +
        summaryText +
        '" id="book-cal-summary" aria-live="polite">' +
        selectedLabel()
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;') +
        '</p>' +
        '<div class="flex shrink-0 items-center gap-1">' +
        '<button type="button" data-cal-prev class="flex ' +
        navSz +
        ' items-center justify-center rounded-lg border border-cyan-500/35 bg-black/50 text-cyan-300 transition-colors hover:border-fuchsia-500/40 hover:bg-fuchsia-500/10 hover:text-fuchsia-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-500/50 disabled:pointer-events-none disabled:opacity-25 touch-manipulation" aria-label="' +
        calPrev.replace(/"/g, '&quot;') +
        '"' +
        (cp ? '' : ' disabled') +
        '><svg class="' +
        navSvg +
        '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6"/></svg></button>' +
        '<button type="button" data-cal-next class="flex ' +
        navSz +
        ' items-center justify-center rounded-lg border border-cyan-500/35 bg-black/50 text-cyan-300 transition-colors hover:border-fuchsia-500/40 hover:bg-fuchsia-500/10 hover:text-fuchsia-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-500/50 disabled:pointer-events-none disabled:opacity-25 touch-manipulation" aria-label="' +
        calNext.replace(/"/g, '&quot;') +
        '"' +
        (cn ? '' : ' disabled') +
        '><svg class="' +
        navSvg +
        '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg></button>' +
        '</div></div>' +
        '<p class="shrink-0 text-center font-display font-bold uppercase text-stone-400 ' +
        monthTitleMb +
        ' ' +
        monthTitleText +
        '">' +
        monthTitle.replace(/&/g, '&amp;').replace(/</g, '&lt;') +
        '</p>';

      var wk = '<div class="grid shrink-0 grid-cols-7 gap-1 text-center ' + wkRowMb + '">';
      for (var wi = 0; wi < 7; wi++) {
        wk += '<div class="' + wkCell + '">' + String(weekdays[wi] || '').replace(/&/g, '&amp;') + '</div>';
      }
      wk += '</div>';

      var grid =
        '<div class="grid min-h-0 flex-1 grid-cols-7 ' +
        gridGap +
        '" style="grid-template-rows: repeat(6, minmax(0, 1fr))">';
      var cur = new Date(y, m, 1 - startPad, 12, 0, 0, 0);
      for (var c = 0; c < 42; c++) {
        var inMonth = cur.getMonth() === m;
        var iso = isoFromDate(cur);
        var isAvail = inMonth && valuesSet[iso];
        var isSel = selected === iso;
        var isToday = iso === todayIso;
        var num = cur.getDate();
        var cls = dayBase + ' h-full w-full';
        if (!inMonth) {
          cls += ' border-transparent bg-transparent text-stone-700/40';
        } else if (!isAvail) {
          cls +=
            ' cursor-not-allowed border-white/[0.05] bg-white/[0.02] text-stone-600/50 line-through decoration-stone-600/40';
        } else if (isSel) {
          cls +=
            ' border-fuchsia-500/70 bg-fuchsia-500/15 text-fuchsia-100 shadow-[0_0_20px_rgba(255,45,106,0.25)]';
        } else {
          cls +=
            ' border-cyan-500/25 bg-black/40 text-stone-200 hover:border-cyan-400/50 hover:bg-cyan-500/10 hover:text-cyan-100';
        }
        if (isToday && inMonth) {
          cls += ' ring-1 ring-cyan-400/50 ring-offset-2 ring-offset-[#060608]';
        }
        if (isAvail) {
          grid +=
            '<button type="button" class="' +
            cls +
            '" data-cal-day="' +
            iso +
            '" aria-pressed="' +
            (isSel ? 'true' : 'false') +
            '">' +
            num +
            '</button>';
        } else {
          grid += '<div class="' + cls + ' pointer-events-none" aria-hidden="true">' + (inMonth ? num : '') + '</div>';
        }
        cur.setDate(cur.getDate() + 1);
      }
      grid += '</div>';

      var foot = '';
      if (!hasAny) {
        foot =
          '<p class="mt-3 text-center text-xs text-stone-500">' +
          calEmpty.replace(/&/g, '&amp;').replace(/</g, '&lt;') +
          '</p>';
      }
      foot += '</div>';

      root.innerHTML = head + wk + grid + foot;

      var prevBtn = root.querySelector('[data-cal-prev]');
      var nextBtn = root.querySelector('[data-cal-next]');
      if (prevBtn)
        prevBtn.addEventListener('click', function () {
          if (!canGoPrev()) return;
          view.setMonth(view.getMonth() - 1);
          render();
        });
      if (nextBtn)
        nextBtn.addEventListener('click', function () {
          if (!canGoNext()) return;
          view.setMonth(view.getMonth() + 1);
          render();
        });

      Array.prototype.forEach.call(root.querySelectorAll('[data-cal-day]'), function (btn) {
        btn.addEventListener('click', function () {
          var iso = btn.getAttribute('data-cal-day');
          if (!iso) return;
          select.value = iso;
          select.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });
    }

    select.addEventListener('change', function () {
      var v = select.value;
      if (v) {
        var sd = parseIso(v);
        view.setFullYear(sd.getFullYear(), sd.getMonth(), 1);
      }
      render();
    });
    render();
  }

  function mountTimeSlotGrid() {
    var slots = [];
    try {
      slots = JSON.parse(nightSlotsJson);
    } catch (e) {
      slots = [];
    }
    var select = document.getElementById('book-time');
    var root = document.getElementById('book-time-grid-root');
    if (!select || !root || !(select instanceof HTMLSelectElement)) return;

    function esc(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function summaryText() {
      var v = select.value;
      if (!v) return calPickTime;
      return v;
    }

    function render() {
      var selected = select.value;
      var timeRowCount = Math.max(1, Math.ceil(slots.length / 2));
      var head =
        '<div class="flex min-h-0 flex-1 flex-col rounded-xl border border-cyan-500/25 bg-black/45 p-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] sm:p-3">' +
        '<div class="mb-2 shrink-0 border-b border-white/[0.06] pb-2">' +
        '<p class="min-w-0 font-display text-xs font-semibold uppercase tracking-[0.12em] text-cyan-200/95" id="book-time-summary" aria-live="polite">' +
        esc(summaryText()) +
        '</p></div>' +
        '<div class="grid min-h-0 flex-1 grid-cols-2 gap-1 sm:gap-1.5" style="grid-template-rows: repeat(' +
        timeRowCount +
        ', minmax(0, 1fr))">';

      var body = '';
      for (var i = 0; i < slots.length; i++) {
        var t = slots[i];
        var isSel = selected === t;
        var cls =
          'flex h-full min-h-[2.25rem] w-full items-center justify-center rounded-lg border text-xs font-semibold tabular-nums transition-all touch-manipulation sm:min-h-[2.5rem] sm:text-sm';
        if (isSel) {
          cls +=
            ' border-fuchsia-500/70 bg-fuchsia-500/15 text-fuchsia-100 shadow-[0_0_16px_rgba(255,45,106,0.22)]';
        } else {
          cls +=
            ' border-cyan-500/25 bg-black/40 text-stone-200 hover:border-cyan-400/50 hover:bg-cyan-500/10 hover:text-cyan-100';
        }
        body +=
          '<button type="button" class="' +
          cls +
          '" data-time-slot="' +
          esc(t) +
          '" aria-pressed="' +
          (isSel ? 'true' : 'false') +
          '">' +
          esc(t) +
          '</button>';
      }

      root.innerHTML = head + body + '</div></div>';

      Array.prototype.forEach.call(root.querySelectorAll('[data-time-slot]'), function (btn) {
        btn.addEventListener('click', function () {
          var v = btn.getAttribute('data-time-slot');
          if (!v) return;
          select.value = v;
          select.dispatchEvent(new Event('change', { bubbles: true }));
        });
      });
    }

    select.addEventListener('change', render);
    render();
  }

  const form = document.getElementById('booking-form');
  const statusEl = document.getElementById('booking-status');
  const defaultSlug = form?.getAttribute('data-default-masseuse')?.trim();

  mountMasseusePicker();
  mountNightCalendar();
  mountTimeSlotGrid();

  form?.querySelector('#book-masseuse')?.addEventListener('change', function syncPickerFromSelect() {
    var trigger = document.getElementById('book-masseuse-trigger');
    var hidden = document.getElementById('book-masseuse');
    if (!trigger || !hidden) return;
    var v = hidden.value;
    var m = MASSEUSES.find(function (x) {
      return x.slug === v;
    });
    var imgWrap = trigger.querySelector('[data-thumb-wrap]');
    var img = trigger.querySelector('[data-thumb]');
    var label = trigger.querySelector('[data-label]');
    if (!imgWrap || !img || !label) return;
    if (m) {
      imgWrap.classList.remove('hidden');
      img.src = m.image;
      label.textContent = m.name;
    } else {
      imgWrap.classList.add('hidden');
      img.removeAttribute('src');
      label.textContent = selectHostLabel;
    }
    var list = document.getElementById('book-masseuse-listbox');
    if (list) {
      Array.prototype.forEach.call(list.querySelectorAll('[role="option"]'), function (opt) {
        var sel = opt.getAttribute('data-slug') === v;
        opt.setAttribute('aria-selected', sel ? 'true' : 'false');
        opt.classList.toggle('bg-cyan-500/15', sel);
        opt.classList.toggle('border-cyan-500/30', sel);
      });
    }
  });

  const params = new URLSearchParams(window.location.search);
  const qHost = params.get('host');

  if (form && defaultSlug) {
    const sel = form.querySelector('#book-masseuse');
    if (sel instanceof HTMLSelectElement) {
      sel.value = defaultSlug;
      sel.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }

  if (form && qHost) {
    const sel = form.querySelector('#book-masseuse');
    if (sel instanceof HTMLSelectElement) {
      const opt = Array.from(sel.options).find((o) => o.value === qHost);
      if (opt) {
        sel.value = qHost;
        sel.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
  }

  const qDate = params.get('date');
  if (form && qDate) {
    const sel = form.querySelector('#book-date');
    if (sel instanceof HTMLSelectElement) {
      const opt = Array.from(sel.options).find((o) => o.value === qDate);
      if (opt) {
        sel.value = qDate;
        sel.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
  }

  const qService = params.get('service');
  if (form && qService) {
    const sel = form.querySelector('#book-service');
    if (sel) {
      const opt = Array.from(sel.options).find((o) => o.value === qService);
      if (opt) sel.value = qService;
    }
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!statusEl || !form) return;
    const fd = new FormData(form);
    const host = fd.get('masseuse');
    const svc = fd.get('service');
    statusEl.classList.remove('hidden');
    statusEl.textContent = demoTpl
      .replace('{host}', String(host ?? ''))
      .replace('{service}', String(svc ?? ''));
    statusEl.classList.add('animate-pulse');
    setTimeout(() => statusEl.classList.remove('animate-pulse'), 2000);
  });
</script>
