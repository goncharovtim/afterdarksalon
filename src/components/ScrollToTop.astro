---
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';

type Props = { lang: Lang };

const { lang } = Astro.props;
const label = t(lang, 'a11y.scrollToTop');
---

<button
  type="button"
  tabindex="-1"
  class="scroll-to-top fixed z-[60] flex size-11 sm:size-12 items-center justify-center rounded-full border border-cyan-500/40 bg-void/90 text-cyan-300 shadow-[0_0_24px_rgba(0,240,255,0.15)] backdrop-blur-md transition-[opacity,transform,box-shadow] duration-300 hover:border-fuchsia-500/50 hover:text-fuchsia-200 hover:shadow-[0_0_28px_rgba(255,45,106,0.25)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-400 motion-safe:active:scale-95 translate-y-4 opacity-0 pointer-events-none [&[data-visible]]:translate-y-0 [&[data-visible]]:opacity-100 [&[data-visible]]:pointer-events-auto end-4 max-md:bottom-[calc(5.5rem+env(safe-area-inset-bottom))] sm:bottom-[calc(1.25rem+env(safe-area-inset-bottom))] md:bottom-8 md:end-6"
  aria-label={label}
  data-scroll-to-top
>
  <svg class="size-5 sm:size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"></path>
  </svg>
</button>

<script>
  const btn = document.querySelector('[data-scroll-to-top]');
  if (btn instanceof HTMLButtonElement) {
    const showAfter = 320;
    const root = document.documentElement;
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    const setVisible = (visible: boolean) => {
      if (visible) {
        btn.setAttribute('data-visible', '');
        btn.tabIndex = 0;
      } else {
        btn.removeAttribute('data-visible');
        btn.tabIndex = -1;
      }
    };

    const onScroll = () => {
      setVisible(window.scrollY > showAfter);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    btn.addEventListener('click', () => {
      if (mqReduce.matches) {
        window.scrollTo(0, 0);
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
      btn.focus({ preventScroll: true });
    });
  }
</script>
