---
import { featuredMasseuses } from '../data/site';
import { getMasseuseDetail } from '../data/masseuseDetails';
import { pathBook, pathMasseuse } from '../i18n/paths';
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';

type Props = { lang: Lang };

const { lang } = Astro.props;

const locale = lang === 'cs' ? 'cs-CZ' : 'en-GB';

const payload = {
  bookBase: pathBook(lang),
  locale,
  labels: {
    today: t(lang, 'scheduleGrid.today'),
    salonClosed: t(lang, 'scheduleGrid.salonClosed'),
    dayOff: t(lang, 'scheduleGrid.dayOff'),
    shiftShort: t(lang, 'scheduleGrid.shiftShort'),
    shiftHours: t(lang, 'scheduleGrid.shiftHours'),
    bookSlot: t(lang, 'scheduleGrid.bookSlot'),
    profile: t(lang, 'scheduleGrid.profile'),
    hostCol: t(lang, 'scheduleGrid.hostCol'),
  },
  hosts: featuredMasseuses.map((m) => {
    const d = getMasseuseDetail(m.slug);
    const open = d?.schedule.map((x) => x.open) ?? [false, false, false, false, false, false, false];
    const st = d?.stats;
    return {
      slug: m.slug,
      name: m.name,
      image: m.image,
      profileHref: pathMasseuse(lang, m.slug),
      openByWeekday: open,
      stats:
        st && (st.age || st.height || st.weight)
          ? { age: st.age ?? '', height: st.height ?? '', weight: st.weight ?? '' }
          : null,
    };
  }),
};

const payloadJson = JSON.stringify(payload);
---

<div
  class="rounded-2xl border border-cyan-500/15 bg-black/30 overflow-hidden shadow-[0_24px_80px_-40px_rgba(0,0,0,0.9)]"
  data-masseuse-schedule-root
>
  <div class="overflow-x-auto scrollbar-cyber">
    <table class="w-full min-w-[72rem] table-fixed border-collapse text-left">
      <colgroup>
        <col style="width: 17rem" />
        <col /><col /><col /><col /><col /><col /><col />
      </colgroup>
      <thead>
        <tr id="msch-head-row" class="border-b border-white/[0.08]">
          <th
            scope="col"
            class="sticky left-0 z-30 border-b border-white/[0.08] border-r border-white/[0.06] bg-void/95 px-3 py-3 text-left align-top backdrop-blur-md"
          >
            <span class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-stone-500">
              {t(lang, 'scheduleGrid.hostCol')}
            </span>
          </th>
        </tr>
      </thead>
      <tbody id="msch-body" class="divide-y divide-white/[0.06]"></tbody>
    </table>
  </div>
</div>

<script is:inline define:vars={{ payloadJson }}>
  (function () {
    var payload = JSON.parse(payloadJson);
    var L = payload.labels;
    var hosts = payload.hosts;
    var bookBase = payload.bookBase;
    var locale = payload.locale;

    function escAttr(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/</g, '&lt;');
    }

    function isoLocal(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var day = String(d.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + day;
    }

    function dayIndex(d) {
      var w = d.getDay();
      return w === 0 ? 6 : w - 1;
    }

    function salonNight(w) {
      return w === 4 || w === 5 || w === 6;
    }

    function cellKind(d, openByWeekday) {
      var w = d.getDay();
      if (!salonNight(w)) return 'salonClosed';
      if (!openByWeekday[dayIndex(d)]) return 'off';
      return 'shift';
    }

    function statsHtml(h) {
      var s = h.stats;
      if (!s) return '';
      var parts = [];
      if (s.age) parts.push(s.age);
      if (s.height) parts.push(s.height);
      if (s.weight) parts.push(s.weight);
      if (!parts.length) return '';
      return (
        '<div class="mt-2 text-[9px] leading-snug text-stone-500/90 tabular-nums">' +
        escAttr(parts.join(' · ')) +
        '</div>'
      );
    }

    var headRow = document.getElementById('msch-head-row');
    var bodyEl = document.getElementById('msch-body');
    if (!headRow || !bodyEl) return;

    var anchor = new Date();
    anchor.setHours(12, 0, 0, 0);
    var todayIso = isoLocal(anchor);
    var days = [];
    for (var i = 0; i < 7; i++) {
      var x = new Date(anchor);
      x.setDate(anchor.getDate() + i);
      days.push(x);
    }

    days.forEach(function (d) {
      var wd = d.toLocaleDateString(locale, { weekday: 'short' });
      var dm = d.toLocaleDateString(locale, { day: 'numeric', month: 'short' });
      var todayMark =
        isoLocal(d) === todayIso
          ? '<span class="text-fuchsia-400">' + L.today + '</span>'
          : '<span class="text-transparent select-none pointer-events-none" aria-hidden="true">' + L.today + '</span>';
      var th = document.createElement('th');
      th.scope = 'col';
      th.className =
        'border-b border-white/[0.08] bg-black/40 px-2 py-2.5 text-center align-top min-w-0';
      th.innerHTML =
        '<div class="rounded-lg border border-white/[0.08] bg-black/50 px-1.5 py-2 min-h-[4.25rem] flex flex-col justify-center">' +
        '<div class="font-display text-[10px] font-bold uppercase tracking-wider text-stone-300 leading-tight">' +
        escAttr(wd) +
        '</div>' +
        '<div class="text-[11px] text-stone-500 mt-1 leading-tight">' +
        escAttr(dm) +
        '</div>' +
        '<div class="text-[9px] mt-1 min-h-[1.25rem] uppercase tracking-wider leading-tight">' +
        todayMark +
        '</div>' +
        '</div>';
      headRow.appendChild(th);
    });

    function barHtml(kind) {
      if (kind === 'shift') {
        return (
          '<div class="mt-2 h-1.5 rounded-full bg-stone-800/90 overflow-hidden">' +
          '<div class="h-full w-[58%] rounded-full bg-gradient-to-r from-emerald-500/90 via-cyan-500 to-fuchsia-500/80"></div>' +
          '</div>'
        );
      }
      if (kind === 'off') {
        return (
          '<div class="mt-2 h-1.5 rounded-full bg-stone-800/80">' +
          '<div class="h-full w-full rounded-full bg-stone-600/50"></div>' +
          '</div>'
        );
      }
      return (
        '<div class="mt-2 h-1.5 rounded-full bg-stone-900">' +
        '<div class="h-full w-full rounded-full bg-stone-800/60"></div>' +
        '</div>'
      );
    }

    function cellInner(kind, bookUrl, name, dateStr) {
      var title = '';
      var sub = '';
      var accent = '';
      if (kind === 'salonClosed') {
        title = L.salonClosed;
        sub = '';
        accent = 'text-stone-600';
      } else if (kind === 'off') {
        title = L.dayOff;
        sub = '';
        accent = 'text-rose-400/70';
      } else {
        title = L.shiftShort;
        sub = L.shiftHours;
        accent = 'text-cyan-200/95';
      }

      var inner =
        '<div class="text-[11px] font-semibold ' +
        accent +
        ' leading-tight">' +
        title +
        '</div>' +
        (sub
          ? '<div class="text-[10px] text-stone-500 mt-1 leading-tight">' + sub + '</div>'
          : '') +
        barHtml(kind) +
        (kind === 'shift'
          ? '<div class="mt-2 font-display text-[9px] uppercase tracking-[0.15em] text-fuchsia-400/90">' +
            L.bookSlot +
            ' →</div>'
          : '');

      if (kind === 'shift' && bookUrl) {
        return (
          '<a href="' +
          escAttr(bookUrl) +
          '" class="block min-h-[8rem] rounded-xl border border-white/[0.08] bg-black/35 p-3 transition-all hover:border-cyan-500/45 hover:bg-cyan-500/[0.06] hover:shadow-[0_0_20px_rgba(0,240,255,0.12)] touch-manipulation focus:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-500/50" title="' +
          escAttr(name + ' · ' + dateStr) +
          '">' +
          inner +
          '</a>'
        );
      }
      return (
        '<div class="min-h-[8rem] rounded-xl border border-white/[0.05] bg-black/20 p-3 opacity-75">' + inner + '</div>'
      );
    }

    bodyEl.innerHTML = hosts
      .map(function (h) {
        var cells = days
          .map(function (d) {
            var kind = cellKind(d, h.openByWeekday);
            var iso = isoLocal(d);
            var url = kind === 'shift' ? bookBase + '?host=' + encodeURIComponent(h.slug) + '&date=' + iso : '';
            return '<td class="p-2 align-top">' + cellInner(kind, url, h.name, iso) + '</td>';
          })
          .join('');

        return (
          '<tr class="hover:bg-white/[0.02]">' +
          '<th scope="row" class="sticky left-0 z-20 w-[17rem] min-w-[17rem] max-w-[17rem] border-r border-white/[0.06] bg-void/95 p-2.5 text-left align-top backdrop-blur-md">' +
          '<a href="' +
          escAttr(h.profileHref) +
          '" class="group/host flex items-start gap-3 rounded-xl p-1.5 -m-1 transition-colors hover:bg-white/[0.04] touch-manipulation">' +
          '<span class="relative h-[5.25rem] w-[3.85rem] shrink-0 overflow-hidden rounded-xl border border-white/10 shadow-[0_10px_28px_rgba(0,0,0,0.5)]">' +
          '<img src="' +
          escAttr(h.image) +
          '" alt="" class="size-full object-cover object-top" width="62" height="84" loading="lazy" />' +
          '</span>' +
          '<span class="min-w-0 flex-1 pt-0.5">' +
          '<span class="font-display text-[11px] font-bold uppercase tracking-[0.12em] text-white transition-colors group-hover/host:text-cyan-200 [overflow-wrap:anywhere]">' +
          escAttr(h.name) +
          '</span>' +
          statsHtml(h) +
          '<span class="mt-2 block font-display text-[9px] uppercase tracking-[0.18em] text-cyan-500/75 transition-colors group-hover/host:text-fuchsia-400/90">' +
          L.profile +
          ' →</span>' +
          '</span>' +
          '</a>' +
          '</th>' +
          cells +
          '</tr>'
        );
      })
      .join('');
  })();
</script>
