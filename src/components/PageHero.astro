---
/**
 * Unified page title band: equal vertical padding and even spacing between eyebrow / title / body.
 */
type Props = {
  variant?: 'cyan' | 'fuchsia' | 'book';
  /** `contained` = narrow section (e.g. contacts); `full` = full-width band + inner max-w-7xl */
  layout?: 'full' | 'contained';
};

const { variant = 'cyan', layout = 'full' } = Astro.props;

/** Vertical padding lives on `<section>` so the coloured band is symmetric; inner is horizontal + stack only. */
const sectionFull =
  variant === 'fuchsia'
    ? 'border-b border-fuchsia-500/15 bg-surface/25 pt-4 pb-6 md:pt-5 md:pb-8'
    : variant === 'book'
      ? 'relative border-b border-cyan-500/15 overflow-hidden pt-4 pb-6 md:pt-5 md:pb-8'
      : 'border-b border-cyan-500/15 bg-surface/20 pt-4 pb-6 md:pt-5 md:pb-8';

const sectionContained =
  'max-w-6xl mx-auto pt-4 pb-6 md:pt-5 md:pb-8 ps-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] sm:ps-[max(1.25rem,env(safe-area-inset-left,0px))] sm:pe-[max(1.25rem,env(safe-area-inset-right,0px))] text-center border-b border-cyan-500/10';

const innerFull =
  'relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center ps-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] sm:ps-[max(1.25rem,env(safe-area-inset-left,0px))] sm:pe-[max(1.25rem,env(safe-area-inset-right,0px))] text-center';
const innerBook = innerFull;
const innerContained = 'flex w-full flex-col items-center';
---

<section class:list={[layout === 'full' ? sectionFull : sectionContained]}>
  {
    variant === 'book' && layout === 'full' && (
      <div class="absolute inset-0 cyber-grid-bg opacity-40 pointer-events-none" aria-hidden="true" />
    )
  }
  <div class:list={[layout === 'full' ? (variant === 'book' ? innerBook : innerFull) : innerContained]}>
    <div class="flex w-full flex-col items-center gap-2.5 md:gap-3">
      <slot name="eyebrow" />
      <slot name="title" />
      <div class="page-hero-default w-full flex flex-col items-center [&_p]:!leading-snug sm:[&_p]:!leading-normal">
        <slot />
      </div>
    </div>
  </div>
</section>
