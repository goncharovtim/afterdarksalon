---
import type { Lang } from '../i18n/types';
import type { MasseuseStats } from '../data/masseuseDetails';
import { t } from '../i18n/t';

type Props = {
  lang: Lang;
  stats: MasseuseStats;
  compact?: boolean;
};

const { lang, stats, compact = false } = Astro.props;

type StatKind = 'age' | 'bust' | 'height' | 'weight' | 'tattoos';

type Row = { kind: StatKind; labelKey: string; value: string | undefined };

/** Icons in `public/girlsparam` (paths are case-sensitive on Linux). */
const STAT_ICONS: Record<StatKind, string> = {
  age: '/girlsparam/age.png',
  bust: '/girlsparam/tits.png',
  height: '/girlsparam/Height.png',
  weight: '/girlsparam/Weight.png',
  tattoos: '/girlsparam/Tattoos.png',
};

function displayValue(kind: StatKind, raw: string): string {
  if (kind === 'tattoos') {
    const v = raw.trim().toLowerCase();
    if (v === 'yes') return t(lang, 'masseuses.tattooYes');
    if (v === 'no') return t(lang, 'masseuses.tattooNo');
  }
  return raw;
}

const rows: Row[] = [
  { kind: 'age', labelKey: 'masseuses.cardAge', value: stats.age },
  { kind: 'bust', labelKey: 'masseuses.cardBust', value: stats.bust },
  { kind: 'height', labelKey: 'masseuses.cardHeight', value: stats.height },
  { kind: 'weight', labelKey: 'masseuses.cardWeight', value: stats.weight },
  { kind: 'tattoos', labelKey: 'masseuses.cardTattoo', value: stats.tattoos },
];

const visible = rows.filter((r) => r.value && String(r.value).trim().length > 0);
const lastIdx = visible.length - 1;
---

{
  visible.length > 0 && (
    <>
      {
        compact ? (
          <div class="flex flex-wrap items-start gap-x-3 gap-y-2.5" role="list">
            {visible.map((row) => (
              <div
                class="flex min-w-0 max-w-[5.5rem] items-center gap-2 sm:max-w-[6rem]"
                role="listitem"
              >
                <img
                  src={STAT_ICONS[row.kind]}
                  alt=""
                  width="20"
                  height="20"
                  class="size-5 shrink-0 object-contain opacity-90 [filter:drop-shadow(0_0_4px_rgba(34,211,238,0.12))]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="min-w-0 flex-1">
                  <p class="text-[8px] font-medium uppercase leading-tight tracking-wider text-stone-500">
                    {t(lang, row.labelKey)}
                  </p>
                  <p class="mt-0.5 text-sm font-semibold tabular-nums leading-snug text-stone-100">
                    {displayValue(row.kind, String(row.value))}
                  </p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div
            class="grid grid-cols-2 gap-x-5 gap-y-5 sm:grid-cols-3 sm:gap-x-6 sm:gap-y-4"
            role="list"
          >
            {visible.map((row, i) => (
              <div
                class:list={[
                  'flex min-w-0 items-center gap-3',
                  visible.length === 5 && i === lastIdx
                    ? 'col-span-2 justify-center sm:col-span-1 sm:col-start-2 sm:justify-center'
                    : '',
                ]}
                role="listitem"
              >
                <img
                  src={STAT_ICONS[row.kind]}
                  alt=""
                  width="40"
                  height="40"
                  class="size-9 shrink-0 object-contain opacity-90 sm:size-10 [filter:drop-shadow(0_0_5px_rgba(34,211,238,0.14))]"
                  loading="lazy"
                  decoding="async"
                />
                <div class="min-w-0 text-start">
                  <p class="text-[10px] font-medium uppercase leading-tight tracking-wider text-stone-500 sm:text-[11px]">
                    {t(lang, row.labelKey)}
                  </p>
                  <p class="mt-0.5 text-sm font-semibold tabular-nums leading-snug text-stone-100 sm:text-base">
                    {displayValue(row.kind, String(row.value))}
                  </p>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </>
  )
}
