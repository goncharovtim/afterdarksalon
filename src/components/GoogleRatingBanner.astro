---
import { googleReviews } from '../data/site';
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';

type Props = {
  lang: Lang;
  variant?: 'hero' | 'footer';
};

const { lang, variant = 'footer' } = Astro.props;
const { url, rating, reviewCount } = googleReviews;

const fmt =
  lang === 'cs'
    ? new Intl.NumberFormat('cs-CZ', { minimumFractionDigits: 1, maximumFractionDigits: 1 })
    : new Intl.NumberFormat('en-GB', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
const ratingStr = fmt.format(rating);

const starPath =
  'M10 1.5l2.47 5.01L18 7.36l-4 3.9.94 5.49L10 14.77l-4.94 2.98.94-5.49-4-3.9 5.53-.85L10 1.5z';

function starFill(i: number): number {
  const v = rating - i;
  return Math.min(1, Math.max(0, v));
}
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${t(lang, 'googleRating.ratedOnGoogle')}: ${ratingStr} · ${reviewCount} ${t(lang, 'googleRating.reviewsCount')}. ${t(lang, 'googleRating.seeOnMaps')}`}
  class:list={[
    'group flex flex-wrap items-center justify-center gap-3 rounded-xl border transition-all',
    variant === 'hero' &&
      'border-cyan-500/25 bg-void/60 px-4 py-3 hover:border-cyan-500/45 hover:bg-void/80 hover:shadow-[0_0_28px_rgba(0,240,255,0.12)]',
    variant === 'footer' &&
      'border-fuchsia-500/20 bg-surface/40 px-5 py-4 md:px-8 md:py-5 hover:border-fuchsia-500/40 hover:shadow-[0_0_32px_rgba(217,70,239,0.12)]',
  ]}
>
  <span
    class="font-display text-[10px] font-bold uppercase tracking-[0.2em] text-stone-500 group-hover:text-stone-400"
    aria-hidden="true"
  >
    {t(lang, 'googleRating.ratedOnGoogle')}
  </span>
  <span class="flex items-center gap-2" aria-hidden="true">
    <span class="flex gap-0.5" aria-hidden="true">
      {
        [0, 1, 2, 3, 4].map((i) => {
          const fill = starFill(i);
          return (
            <span class="relative inline-block size-[1.125rem] shrink-0">
              <svg class="absolute inset-0 size-[1.125rem] text-stone-700" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} class="opacity-35" />
              </svg>
              {fill > 0 && (
                <span class="absolute inset-0 overflow-hidden" style={`width: ${fill * 100}%`}>
                  <svg class="size-[1.125rem] text-amber-400 drop-shadow-[0_0_6px_rgba(251,191,36,0.45)]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d={starPath} />
                  </svg>
                </span>
              )}
            </span>
          );
        })
      }
    </span>
    <span class="font-display text-sm font-bold tabular-nums text-white">{ratingStr}</span>
    <span class="text-sm text-stone-500">
      · {reviewCount} {t(lang, 'googleRating.reviewsCount')}
    </span>
  </span>
  <span
    class="font-display text-[10px] uppercase tracking-wider text-cyan-400/90 group-hover:text-cyan-300 underline-offset-2 group-hover:underline"
    aria-hidden="true"
  >
    {t(lang, 'googleRating.seeOnMaps')}
  </span>
</a>
