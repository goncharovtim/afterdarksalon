---
import type { Lang } from '../i18n/types';
import type { MasseuseStats } from '../data/masseuseDetails';
import MasseuseStatsBar from './MasseuseStatsBar.astro';

type Props = {
  lang: Lang;
  name: string;
  image: string;
  vibe?: string;
  stats?: MasseuseStats;
  /** Slightly smaller type on home tiles */
  compact?: boolean;
};

const { lang, name, image, vibe, stats, compact = false } = Astro.props;

function hasAnyStat(s: MasseuseStats | undefined): boolean {
  if (!s) return false;
  return Boolean(
    s.age?.trim() ||
      s.bust?.trim() ||
      s.height?.trim() ||
      s.weight?.trim() ||
      s.tattoos?.trim(),
  );
}

const hasStats = hasAnyStat(stats);
const titleClass = compact
  ? 'font-display text-lg sm:text-xl font-bold uppercase tracking-wide text-white'
  : 'font-display text-xl sm:text-2xl font-bold uppercase text-white';
const imgTone = compact ? 'opacity-90 group-hover:opacity-100' : '';
---

<div class="relative h-full w-full min-h-[12rem] overflow-hidden bg-black">
  <img
    src={image}
    alt={name}
    width="350"
    height="500"
    class:list={[
      'h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100',
      imgTone,
    ]}
    loading="lazy"
    decoding="async"
  />
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/95 via-void/15 to-transparent opacity-80" />

  {
    hasStats && stats ? (
      <>
        <div class="absolute bottom-0 left-0 right-0 z-10 p-4 transition-opacity duration-300 ease-out motion-reduce:transition-none group-hover:opacity-0 group-hover:pointer-events-none">
          <h2 class:list={[titleClass, 'drop-shadow-md']}>{name}</h2>
          {vibe && (
            <p class="text-[10px] sm:text-xs text-fuchsia-400/90 font-display uppercase tracking-widest mt-1">
              {vibe}
            </p>
          )}
        </div>

        <div
          class:list={[
            'absolute inset-x-0 bottom-0 z-20 flex flex-col justify-end p-4 pt-14 sm:pt-16',
            'bg-gradient-to-t from-black/95 via-black/88 to-black/25',
            'opacity-0 translate-y-2 transition-all duration-300 ease-out motion-reduce:transition-none',
            'group-hover:opacity-100 group-hover:translate-y-0',
          ]}
        >
          <h2 class:list={[titleClass, 'text-white']}>{name}</h2>
          {vibe && (
            <p class="text-[10px] sm:text-xs text-fuchsia-300/90 font-display uppercase tracking-widest mt-0.5">
              {vibe}
            </p>
          )}
          <div class="mt-3 border-t border-white/[0.08] pt-3">
            <MasseuseStatsBar lang={lang} stats={stats} compact />
          </div>
        </div>
      </>
    ) : (
      <div class="absolute bottom-0 left-0 right-0 z-10 p-4">
        <h2 class:list={[titleClass, 'drop-shadow-md']}>{name}</h2>
        {vibe && (
          <p class="text-[10px] sm:text-xs text-fuchsia-400/90 font-display uppercase tracking-widest mt-1">
            {vibe}
          </p>
        )}
      </div>
    )
  }
</div>
