---
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';

type Props = {
  items: readonly string[];
  lang: Lang;
  hostName: string;
  class?: string;
};

const { items, lang, hostName, class: className } = Astro.props;
const extrasHeading = t(lang, 'masseuseServices.extrasTitleWithName').replace('{name}', hostName);
const shell = className ?? 'card-cyber p-5 md:p-6';
---

{
  items.length > 0 && (
    <div class:list={[shell]}>
      <h2 class="font-display text-[11px] sm:text-sm font-semibold normal-case tracking-wide text-cyan-400/90 mb-3 [text-wrap:pretty]">
        {extrasHeading}
      </h2>
      <ul class="flex flex-col gap-1.5">
        {items.map((line) => (
          <li
            class="rounded-xl border border-white/[0.08] bg-white/[0.03] px-3 py-2.5 text-[13px] sm:text-sm text-stone-200 min-h-10 flex items-center"
          >
            {line}
          </li>
        ))}
      </ul>
    </div>
  )
}
