---
import type { DaySchedule } from '../data/masseuseDetails';
import type { Lang } from '../i18n/types';
import { t, tArr } from '../i18n/t';

type Props = {
  schedule: DaySchedule[];
  lang: Lang;
  title?: string;
  class?: string;
  compact?: boolean;
};

const { schedule, lang, title, class: className, compact = false } = Astro.props;
const titleFinal = title ?? t(lang, 'schedule.shiftTitle');
const shorts = tArr(lang, 'schedule.shorts');
const shell =
  className ?? (compact ? 'card-cyber p-3.5 sm:p-4' : 'card-cyber p-5 md:p-6');
---

<div class:list={[shell]}>
  <h2 class="font-display text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] text-cyan-400 mb-0.5">
    {titleFinal}
  </h2>
  <p class="text-[10px] text-stone-500 uppercase tracking-wider mb-3">
    {t(lang, 'schedule.subtitle')}
  </p>
  {
    compact ? (
      <div class="flex flex-wrap gap-1.5">
        {schedule.map((d, i) => (
          <div
            class:list={[
              'flex items-center gap-1.5 rounded-md border px-2 py-1.5 min-w-0',
              d.open
                ? 'border-cyan-500/45 bg-cyan-500/[0.08] shadow-[0_0_10px_rgba(0,240,255,0.08)]'
                : 'border-white/[0.07] bg-black/25 opacity-55',
            ]}
          >
            <span class="font-display text-[9px] font-bold text-stone-500 shrink-0">{shorts[i] ?? d.short}</span>
            {d.open ? (
              <span class="text-[9px] leading-none text-cyan-200/85 tabular-nums">{d.hours?.replace(' – ', '–')}</span>
            ) : (
              <span class="text-[9px] text-stone-600 uppercase">{t(lang, 'schedule.off')}</span>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="grid grid-cols-7 gap-1.5 sm:gap-2">
        {schedule.map((d, i) => (
          <div
            class:list={[
              'flex flex-col items-center rounded-lg border px-1 py-2.5 sm:px-2 text-center transition-all',
              d.open
                ? 'border-cyan-500/50 bg-cyan-500/10 shadow-[0_0_12px_rgba(0,240,255,0.15)]'
                : 'border-white/10 bg-black/20 opacity-50',
            ]}
          >
            <span class="font-display text-[10px] sm:text-xs font-bold text-stone-400">
              {shorts[i] ?? d.short}
            </span>
            {d.open ? (
              <>
                <span class="mt-1 size-1.5 rounded-full bg-cyan-400 shadow-[0_0_8px_#00f0ff]" aria-hidden="true" />
                <span class="mt-1 text-[9px] sm:text-[10px] leading-tight text-cyan-200/90 hidden sm:block">
                  {d.hours?.replace(' – ', '–')}
                </span>
              </>
            ) : (
              <span class="mt-1 text-[9px] text-stone-600 uppercase">{t(lang, 'schedule.off')}</span>
            )}
          </div>
        ))}
      </div>
    )
  }
</div>
