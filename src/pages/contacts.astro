---
import Layout from '../layouts/Layout.astro';
import { contact, contactWhatsAppUrl } from '../data/site';
import { t } from '../i18n/t';
import { pathBook } from '../i18n/paths';
import { graphLd, webPageJsonLd } from '../lib/seo';
import PageHero from '../components/PageHero.astro';

const lang = 'cs' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoContactsTitle');
const description = t(lang, 'meta.seoContactsDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);

const mapSrc =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2559.8553379396585!2d14.415938276723411!3d50.088995271525484!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470b94846c847283%3A0x266f7ec1a4e052c5!2sNIRVANA%20Massage!5e0!3m2!1scs!2scz!4v1773402487292!5m2!1scs!2scz';
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <PageHero layout="contained">
    <p
      slot="eyebrow"
      class="font-display text-[10px] font-bold uppercase tracking-[0.3em] text-fuchsia-400"
    >
      {t(lang, 'contacts.eyebrow')}
    </p>
    <h1
      slot="title"
      class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon"
    >
      {t(lang, 'contacts.title')}
    </h1>
    <div class="flex flex-col items-center gap-4">
      <p class="text-base sm:text-lg leading-relaxed">
        <span class="text-cyan-400/90">{t(lang, 'contacts.scheduleHours')}</span>
      </p>
      <a href={pathBook(lang)} class="btn-neon-ghost inline-flex min-h-12 items-center touch-manipulation">
        {t(lang, 'contacts.reserve')}
      </a>
    </div>
  </PageHero>

  <section class="bg-surface/30 border-y border-cyan-500/10">
    <div class="page-content page-content--6xl grid gap-8 lg:grid-cols-2 lg:items-center lg:gap-10">
      <div class="space-y-8 text-stone-300 text-sm sm:text-base">
        <div class="flex gap-4">
          <img
            src="/contactsicons/cal.png"
            alt=""
            width="32"
            height="32"
            class="size-8 shrink-0 object-contain self-start"
            aria-hidden="true"
            loading="lazy"
            decoding="async"
          />
          <p class="leading-relaxed">
            {t(lang, 'contacts.block1')}
            <br />
            <span class="text-fuchsia-400/80 text-sm font-display uppercase tracking-wider"
              >{t(lang, 'contacts.block1b')}</span
            >
          </p>
        </div>
        <div class="flex gap-4">
          <img
            src="/contactsicons/address.png"
            alt=""
            width="32"
            height="32"
            class="size-8 shrink-0 object-contain self-start"
            aria-hidden="true"
            loading="lazy"
            decoding="async"
          />
          <p class="leading-relaxed">
            {t(lang, 'contacts.addressLabel')}{' '}
            <a
              href={contact.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-cyan-400 hover:text-cyan-300 underline-offset-2 touch-manipulation"
            >
              Maiselova 76/12, Praha 1
            </a>
          </p>
        </div>
        <div class="flex gap-4">
          <img
            src="/contactsicons/phone.png"
            alt=""
            width="32"
            height="32"
            class="size-8 shrink-0 object-contain self-start"
            aria-hidden="true"
            loading="lazy"
            decoding="async"
          />
          <p class="leading-relaxed">
            {t(lang, 'contacts.phoneLead')}{' '}
            <a
              href={contactWhatsAppUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-fuchsia-400 hover:text-fuchsia-300 touch-manipulation"
            >
              {contact.phoneDisplay}
            </a>
          </p>
        </div>
      </div>
      <div
        class="contacts-map-dark rounded-xl overflow-hidden border border-cyan-500/25 shadow-[0_0_40px_rgba(0,240,255,0.08)] min-h-[280px]"
      >
        <iframe
          title={t(lang, 'contacts.mapIframeTitle')}
          src={mapSrc}
          width="600"
          height="450"
          class="w-full h-full min-h-[min(50dvh,320px)] border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</Layout>
