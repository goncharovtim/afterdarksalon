---
import Layout from '../../layouts/Layout.astro';
import { featuredMasseuses } from '../../data/site';
import { getMasseuseDetail } from '../../data/masseuseDetails';
import { pickLocale } from '../../i18n/locale';
import { t } from '../../i18n/t';
import { bookWithQuery, pathMasseuse } from '../../i18n/paths';
import { massageTitle } from '../../i18n/massages';
import { graphLd, webPageJsonLd } from '../../lib/seo';
import MasseuseCardImage from '../../components/MasseuseCardImage.astro';
import PageHero from '../../components/PageHero.astro';
import MasseuseGridShuffle from '../../components/MasseuseGridShuffle.astro';
import MasseuseFilterBar from '../../components/MasseuseFilterBar.astro';

const lang = 'cs' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoHostsTitle');
const description = t(lang, 'meta.seoHostsDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <PageHero>
    <p
      slot="eyebrow"
      class="font-display text-[10px] font-bold uppercase tracking-[0.35em] text-cyan-400"
    >
      {t(lang, 'masseuses.eyebrow')}
    </p>
    <h1
      slot="title"
      class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon"
    >
      {t(lang, 'masseuses.title')}
    </h1>
    <p class="text-stone-500 max-w-xl mx-auto text-sm sm:text-base leading-relaxed">
      {t(lang, 'masseuses.lead')}
    </p>
  </PageHero>

  <div class="page-content">
    <MasseuseFilterBar lang={lang} />
    <div id="masseuses-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredMasseuses.map((m) => {
        const d = getMasseuseDetail(m.slug);
        return (
          <div class="host-card-neon-shell h-full min-w-0" data-masseuse-slug={m.slug}>
            <article class="card-cyber flex h-full min-h-0 flex-col overflow-hidden">
            <a
              href={pathMasseuse(lang, m.slug)}
              class="relative aspect-[7/10] overflow-hidden bg-black group block touch-manipulation"
            >
              <MasseuseCardImage
                lang={lang}
                name={m.name}
                image={m.image}
                imageObjectPosition={m.cardImageObjectPosition}
                imageScale={m.cardImageScale}
                vibe={d ? pickLocale(lang, d.vibe) : undefined}
                stats={d?.stats}
              />
            </a>
            <div class="p-4 flex flex-col gap-3 flex-1 border-t border-white/5">
              {d && (
                <ul class="flex flex-wrap gap-1.5">
                  {d.services.map((s) => (
                    <li>
                      <a
                        href={bookWithQuery(lang, { host: m.slug, service: s.slug })}
                        class="inline-flex min-h-9 items-center justify-center rounded border border-cyan-500/25 px-2.5 text-center font-display text-[10px] font-medium uppercase leading-none tracking-wider text-cyan-400/80 transition-colors hover:border-fuchsia-500/40 hover:text-fuchsia-300 touch-manipulation"
                      >
                        {massageTitle(lang, s.slug)}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
              <div class="flex gap-2 mt-auto">
                <a href={pathMasseuse(lang, m.slug)} class="btn-neon-ghost flex-1 justify-center !text-[9px] min-h-11 touch-manipulation">
                  {t(lang, 'masseuses.dossier')}
                </a>
                <a
                  href={bookWithQuery(lang, { host: m.slug })}
                  class="btn-neon-primary flex-1 justify-center !py-2 !text-[9px] min-h-11 touch-manipulation"
                >
                  {t(lang, 'masseuses.reserve')}
                </a>
              </div>
            </div>
          </article>
          </div>
        );
      })}
    </div>
    <p id="masseuses-filter-empty" class="hidden py-10 text-center text-sm text-stone-500" role="status">
      {t(lang, 'masseuses.filterNoResults')}
    </p>
  </div>
  <MasseuseGridShuffle />
</Layout>
