---
import Layout from '../../layouts/Layout.astro';
import PriceBlockTabs from '../../components/PriceBlockTabs.astro';
import { getExtraServiceRows, getPriceBlocks } from '../../data/pricing';
import { t } from '../../i18n/t';
import { graphLd, webPageJsonLd } from '../../lib/seo';
import PageHero from '../../components/PageHero.astro';

const lang = 'en' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoPriceTitle');
const description = t(lang, 'meta.seoPriceDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);

const blocksForLang = getPriceBlocks(lang);
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <PageHero>
    <p
      slot="eyebrow"
      class="font-display text-[10px] font-bold uppercase tracking-[0.35em] text-cyan-400"
    >
      {t(lang, 'price.eyebrow')}
    </p>
    <h1
      slot="title"
      class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon"
    >
      {t(lang, 'price.title')}
    </h1>
  </PageHero>
  <div class="page-content space-y-8">
    <div class="grid gap-8 lg:grid-cols-2">
      {blocksForLang.map((block, index) => (
        <PriceBlockTabs block={block} index={index} lang={lang} />
      ))}
    </div>
    <div class="card-cyber neon-border p-6 md:p-8 max-w-3xl mx-auto overflow-x-auto">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2 sm:gap-3">
        <h2 class="min-w-0 flex-1 font-display text-lg font-bold uppercase tracking-[0.15em] text-fuchsia-400">
          {t(lang, 'price.extraTitle')}
        </h2>
        <img
          src="/priceicons/extra.png"
          alt=""
          width="40"
          height="40"
          class="size-10 shrink-0 object-contain opacity-95 sm:size-11"
          aria-hidden="true"
          loading="lazy"
          decoding="async"
        />
      </div>
      <table class="w-full text-sm min-w-[280px]">
        <tbody class="divide-y divide-white/10">
          {getExtraServiceRows(lang).map((row) => (
            <tr>
              <td class="py-2.5 pe-4 text-stone-300">{row.name}</td>
              <td class="py-2.5 text-cyan-400 text-right whitespace-nowrap font-display text-xs uppercase">
                {row.price}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
