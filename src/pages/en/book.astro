---
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm.astro';
import PageHero from '../../components/PageHero.astro';
import { t } from '../../i18n/t';
import { graphLd, webPageJsonLd } from '../../lib/seo';

const lang = 'en' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoBookTitle');
const description = t(lang, 'meta.seoBookDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <PageHero variant="book">
    <p
      slot="eyebrow"
      class="font-display text-[10px] md:text-xs font-bold uppercase tracking-[0.35em] text-fuchsia-400"
    >
      {t(lang, 'book.pageEyebrow')}
    </p>
    <h1
      slot="title"
      class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase tracking-tight text-gradient-neon"
    >
      {t(lang, 'book.pageTitle')}
    </h1>
    <p class="max-w-2xl mx-auto text-stone-400 text-sm sm:text-base leading-relaxed">
      {t(lang, 'book.pageLead')}
    </p>
  </PageHero>

  <section class="page-content page-content--3xl px-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] sm:px-5">
    <BookingForm lang={lang} />
  </section>
</Layout>
