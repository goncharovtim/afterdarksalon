---
import Layout from '../../layouts/Layout.astro';
import MasseuseScheduleGrid from '../../components/MasseuseScheduleGrid.astro';
import PageHero from '../../components/PageHero.astro';
import { t } from '../../i18n/t';
import { pathBook } from '../../i18n/paths';
import { graphLd, webPageJsonLd } from '../../lib/seo';

const lang = 'en' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoScheduleTitle');
const description = t(lang, 'meta.seoScheduleDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <PageHero>
    <p
      slot="eyebrow"
      class="font-display text-[10px] font-bold uppercase tracking-[0.35em] text-cyan-400"
    >
      {t(lang, 'meta.brand')}
    </p>
    <h1
      slot="title"
      class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon"
    >
      {t(lang, 'scheduleGrid.title')}
    </h1>
    <div class="flex w-full max-w-2xl flex-col items-center gap-3 md:gap-3.5">
      <p class="text-stone-500 text-sm sm:text-base leading-relaxed">
        {t(lang, 'scheduleGrid.lead')}
      </p>
    </div>
  </PageHero>

  <section class="page-content">
    <div class="-mx-4 sm:mx-0">
      <MasseuseScheduleGrid lang={lang} />
    </div>
    <div class="mt-10 text-center">
      <a href={pathBook(lang)} class="btn-neon-primary min-h-12 inline-flex items-center px-8 touch-manipulation">
        {t(lang, 'scheduleGrid.openForm')}
      </a>
    </div>
  </section>
</Layout>
