---
import Layout from '../../layouts/Layout.astro';
import MasseuseScheduleGrid from '../../components/MasseuseScheduleGrid.astro';
import { t } from '../../i18n/t';
import { pathBook } from '../../i18n/paths';
import { graphLd, webPageJsonLd } from '../../lib/seo';

const lang = 'en' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = t(lang, 'meta.seoScheduleTitle');
const description = t(lang, 'meta.seoScheduleDesc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <section class="border-b border-cyan-500/15 bg-surface/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-5 py-12 md:py-16 text-center">
      <p class="font-display text-[10px] font-bold uppercase tracking-[0.35em] text-cyan-400 mb-2">
        {t(lang, 'meta.brand')}
      </p>
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon mb-4">
        {t(lang, 'scheduleGrid.title')}
      </h1>
      <p class="text-stone-500 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed">
        {t(lang, 'scheduleGrid.lead')}
      </p>
      <p class="text-stone-600 text-xs mt-4 max-w-xl mx-auto">{t(lang, 'scheduleGrid.noteClientDates')}</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-5 py-10 md:py-14">
    <MasseuseScheduleGrid lang={lang} />
    <div class="mt-10 text-center">
      <a href={pathBook(lang)} class="btn-neon-primary min-h-12 inline-flex items-center px-8 touch-manipulation">
        {t(lang, 'scheduleGrid.openForm')}
      </a>
    </div>
  </section>
</Layout>
