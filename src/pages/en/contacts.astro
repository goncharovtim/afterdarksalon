---
import Layout from '../../layouts/Layout.astro';
import { contact } from '../../data/site';
import { t } from '../../i18n/t';
import { pathBook } from '../../i18n/paths';
import { graphLd, webPageJsonLd } from '../../lib/seo';

const lang = 'en' as const;
const origin = Astro.site?.origin ?? Astro.url.origin;
const title = `${t(lang, 'meta.docContacts')} | ${t(lang, 'meta.brand')}`;
const description = t(lang, 'contacts.desc');
const jsonLd = graphLd(
  webPageJsonLd({
    origin,
    url: Astro.url.pathname,
    name: title,
    description,
    lang,
  }),
);

const mapSrc =
  'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2559.8553379396585!2d14.415938276723411!3d50.088995271525484!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470b94846c847283%3A0x266f7ec1a4e052c5!2sNIRVANA%20Massage!5e0!3m2!1scs!2scz!4v1773402487292!5m2!1scs!2scz';
---

<Layout lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <section class="max-w-6xl mx-auto px-4 sm:px-5 py-14 md:py-20 text-center border-b border-cyan-500/10">
    <p class="font-display text-[10px] font-bold uppercase tracking-[0.3em] text-fuchsia-400 mb-3">
      {t(lang, 'contacts.eyebrow')}
    </p>
    <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase text-gradient-neon mb-6">
      {t(lang, 'contacts.title')}
    </h1>
    <p class="text-base sm:text-lg text-stone-400 leading-relaxed mb-4">
      {t(lang, 'contacts.scheduleLine')}
      <br />
      <span class="text-cyan-400/90">{t(lang, 'contacts.scheduleHours')}</span>
    </p>
    <a href={pathBook(lang)} class="btn-neon-ghost inline-flex mt-4 min-h-12 items-center touch-manipulation">{t(lang, 'contacts.reserve')}</a>
  </section>

  <section class="bg-surface/30 border-y border-cyan-500/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-5 py-14 md:py-20 grid gap-10 lg:grid-cols-2 lg:gap-12">
      <div class="space-y-8 text-stone-300 text-sm sm:text-base">
        <div class="flex gap-4">
          <span class="text-cyan-400 text-xl shrink-0" aria-hidden="true">📅</span>
          <p class="leading-relaxed">
            {t(lang, 'contacts.block1')}
            <br />
            <span class="text-fuchsia-400/80 text-sm font-display uppercase tracking-wider"
              >{t(lang, 'contacts.block1b')}</span
            >
          </p>
        </div>
        <div class="flex gap-4">
          <span class="text-fuchsia-400 text-xl shrink-0" aria-hidden="true">📍</span>
          <p class="leading-relaxed">
            {t(lang, 'contacts.addressLabel')}{' '}
            <a
              href={contact.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-cyan-400 hover:text-cyan-300 underline-offset-2 touch-manipulation"
            >
              Maiselova 76/12, Praha 1
            </a>
          </p>
        </div>
        <div class="flex gap-4">
          <span class="text-cyan-400 text-xl shrink-0" aria-hidden="true">📞</span>
          <p class="leading-relaxed">
            {t(lang, 'contacts.phoneLead')}{' '}
            <a href={`tel:${contact.phoneTel}`} class="text-fuchsia-400 hover:text-fuchsia-300 touch-manipulation">
              {contact.phoneDisplay}
            </a>
          </p>
        </div>
      </div>
      <div class="rounded-xl overflow-hidden border border-cyan-500/25 shadow-[0_0_40px_rgba(0,240,255,0.08)] min-h-[280px]">
        <iframe
          title={t(lang, 'contacts.mapIframeTitle')}
          src={mapSrc}
          width="600"
          height="450"
          class="w-full h-full min-h-[min(50dvh,320px)] border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</Layout>
