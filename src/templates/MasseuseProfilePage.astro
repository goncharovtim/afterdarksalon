---
import NightSchedule from '../components/NightSchedule.astro';
import MasseuseServices from '../components/MasseuseServices.astro';
import BookingForm from '../components/BookingForm.astro';
import MasseuseStatsBar from '../components/MasseuseStatsBar.astro';
import { contact } from '../data/site';
import type { MasseuseDetail } from '../data/masseuseDetails';
import type { Lang } from '../i18n/types';
import { pickLocale } from '../i18n/locale';
import { t } from '../i18n/t';

type Featured = { name: string; slug: string; image: string };

type Props = {
  lang: Lang;
  slug: string;
  m: Featured | undefined;
  photos: readonly string[];
  detail: MasseuseDetail | undefined;
  bookHref: string;
  masseusesIndexHref: string;
  massagesIndexHref: string;
};

const { lang, slug, m, photos, detail, bookHref, masseusesIndexHref, massagesIndexHref } = Astro.props;

const name = m?.name ?? t(lang, 'masseuses.fallbackName');
const reserveLabel = t(lang, 'masseuses.profileReserve').replace('{name}', name);

const softPanel =
  'rounded-2xl border border-white/[0.07] bg-black/20 p-4 sm:p-5 backdrop-blur-md shadow-[0_20px_60px_-28px_rgba(0,0,0,0.75)]';
const softPanelSchedule =
  'rounded-2xl border border-white/[0.07] bg-black/25 p-3 sm:p-3.5 backdrop-blur-md shadow-[0_16px_48px_-24px_rgba(0,0,0,0.72)]';

const lightboxUrls = m ? (photos.length > 0 ? [...photos] : [m.image]) : [];
const lightboxUrlsJson = JSON.stringify(lightboxUrls);
const galleryCounterTpl = t(lang, 'home.galleryCounter');
---

<article
  class="pb-24 md:pb-10 bg-[radial-gradient(ellipse_90%_50%_at_50%_-8%,rgba(191,95,255,0.07),transparent_58%)]"
>
  <div
    class="mx-auto max-w-7xl px-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] pt-3 sm:px-6 sm:pt-5"
  >
    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between sm:gap-4">
      <nav
        class="inline-flex items-center gap-2 rounded-full border border-white/[0.08] bg-black/35 px-3.5 py-2 text-[10px] font-display uppercase tracking-[0.2em] text-stone-500 backdrop-blur-md max-w-full"
        aria-label="Breadcrumb"
      >
        <a href={masseusesIndexHref} class="hover:text-cyan-400 transition-colors touch-manipulation shrink-0">
          {t(lang, 'masseuses.breadcrumbHosts')}
        </a>
        <span class="text-stone-700 select-none" aria-hidden="true">·</span>
        <span class="text-stone-300 truncate min-w-0">{name}</span>
      </nav>
      <a
        href={masseusesIndexHref}
        class="btn-neon-ghost w-fit min-h-10 px-4 text-[10px] font-display uppercase tracking-[0.18em] touch-manipulation border-white/12 text-stone-300 hover:text-cyan-200"
      >
        {t(lang, 'masseuses.back')}
      </a>
    </div>
  </div>

  <div
    class="mx-auto max-w-7xl px-[max(1rem,env(safe-area-inset-left,0px))] py-6 pe-[max(1rem,env(safe-area-inset-right,0px))] sm:px-6 sm:py-10"
  >
    <div
      class="grid gap-6 lg:gap-8 xl:gap-10 items-start lg:grid-cols-[minmax(0,18rem)_minmax(0,1fr)]"
    >
      <aside class="space-y-5 lg:sticky lg:top-[8.5rem] xl:top-[9rem] self-start">
        {
          m ? (
            <div
              class="max-w-md mx-auto lg:mx-0"
              data-host-profile-gallery
              data-host-gallery-urls={lightboxUrlsJson}
              data-host-gallery-counter-tpl={galleryCounterTpl}
              data-host-gallery-lightbox-label={`${name} — ${t(lang, 'masseuses.photoGallery')}`}
            >
              <div class="relative">
                <div
                  class="pointer-events-none absolute -inset-px rounded-[1.65rem] bg-gradient-to-br from-cyan-500/25 via-transparent to-fuchsia-500/20 opacity-70 blur-[2px]"
                  aria-hidden="true"
                />
                <div class="relative overflow-hidden rounded-3xl border border-white/10 shadow-[0_28px_90px_-24px_rgba(0,0,0,0.92)] ring-1 ring-white/[0.04]">
                  <button
                    type="button"
                    class="group relative block w-full cursor-zoom-in border-0 bg-transparent p-0 text-left touch-manipulation focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400 focus-visible:ring-offset-2 focus-visible:ring-offset-void rounded-3xl"
                    id="host-main-photo-open"
                    aria-label={`${t(lang, 'home.expand')} — ${name}`}
                  >
                    <img
                      id="host-main-photo"
                      src={m.image}
                      alt={name}
                      width="560"
                      height="720"
                      class="aspect-[3/4] w-full object-cover object-top transition-opacity duration-300 pointer-events-none"
                      loading="eager"
                      decoding="async"
                    />
                    <span
                      class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/35 opacity-0 transition-opacity group-hover:opacity-100 group-focus-visible:opacity-100"
                      aria-hidden="true"
                    >
                      <span class="font-display text-[10px] sm:text-xs uppercase tracking-[0.2em] text-white drop-shadow-md">
                        {t(lang, 'home.expand')}
                      </span>
                    </span>
                  </button>
                </div>
              </div>
              {
                photos.length > 1 && (
                  <div class="mt-4">
                    <p class="text-[10px] font-display font-semibold uppercase tracking-[0.25em] text-stone-600 mb-2 lg:text-left text-center">
                      {t(lang, 'masseuses.photoGallery')}
                    </p>
                    <ul
                      class="flex gap-2 overflow-x-auto pb-1.5 -mx-1 px-1 snap-x snap-mandatory scrollbar-cyber touch-pan-x"
                      role="list"
                    >
                      {photos.map((src, i) => (
                        <li class="snap-center shrink-0">
                          <button
                            type="button"
                            class="host-photo-thumb block rounded-xl overflow-hidden border border-white/10 ring-2 ring-transparent transition-all hover:border-cyan-500/40 focus:outline-none focus-visible:ring-cyan-500/50 data-[active]:border-cyan-500/50 data-[active]:ring-cyan-500/30 touch-manipulation cursor-zoom-in"
                            data-host-thumb
                            data-src={src}
                            data-gallery-index={i}
                            data-active={src === m.image ? true : undefined}
                            aria-label={`${name} — ${t(lang, 'masseuses.photoGallery')} ${i + 1}`}
                            aria-pressed={src === m.image ? 'true' : 'false'}
                          >
                            <img
                              src={src}
                              alt=""
                              width="80"
                              height="100"
                              class="h-24 w-[4.75rem] sm:h-28 sm:w-[5.25rem] object-cover object-top"
                              loading="lazy"
                            />
                          </button>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
              <div class="mt-6 text-center lg:text-left space-y-2">
                <p class="text-[10px] font-display font-semibold uppercase tracking-[0.32em] text-fuchsia-400/85">
                  {t(lang, 'masseuses.detailEyebrow')}
                </p>
                <h1 class="font-display text-3xl sm:text-4xl font-semibold text-white tracking-tight [text-wrap:balance]">
                  {name}
                </h1>
                {detail && (
                  <p class="text-sm sm:text-base text-stone-400 leading-relaxed">{pickLocale(lang, detail.vibe)}</p>
                )}
                <p class="text-xs text-stone-600 leading-relaxed pt-1">{t(lang, 'masseuses.metaLine')}</p>
              </div>
            </div>
          ) : (
            <div class="rounded-3xl border border-white/10 bg-surface/40 p-8 text-center">
              <h1 class="font-display text-3xl font-semibold text-white">{name}</h1>
            </div>
          )
        }

        <div class="flex flex-wrap gap-2 lg:hidden">
          <a
            href={bookHref}
            class="btn-neon-primary flex-1 min-w-[min(100%,10rem)] min-h-12 justify-center text-xs touch-manipulation"
          >
            {t(lang, 'masseuses.reserve')}
          </a>
          <a
            href={`tel:${contact.phoneTel}`}
            class="btn-neon-ghost min-h-12 px-5 touch-manipulation border-cyan-500/30 text-cyan-200"
          >
            {t(lang, 'masseuses.ctaCall')}
          </a>
        </div>

        {
          detail && (
            <NightSchedule
              schedule={detail.schedule}
              lang={lang}
              class={softPanelSchedule}
              compact
            />
          )
        }

        <div class="hidden lg:flex flex-col gap-2.5 pt-1">
          <a href={bookHref} class="btn-neon-primary justify-center min-h-11 touch-manipulation text-xs">
            {reserveLabel}
          </a>
          <a
            href={`tel:${contact.phoneTel}`}
            class="btn-neon-ghost justify-center min-h-11 touch-manipulation border-white/15 text-stone-200 text-xs"
          >
            {contact.phoneDisplay}
          </a>
          <a
            href={massagesIndexHref}
            class="text-center text-[10px] font-display uppercase tracking-[0.2em] text-stone-500 hover:text-cyan-400/90 py-1.5 touch-manipulation"
          >
            {t(lang, 'masseuses.allServices')}
          </a>
        </div>
      </aside>

      <div class="min-w-0 flex flex-col gap-8 lg:gap-10">
        {
          detail && (
            <section
              class:list={[softPanel, 'flex flex-col gap-3']}
              aria-labelledby="host-bio-heading"
            >
              <h2
                id="host-bio-heading"
                class="font-display text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.26em] text-fuchsia-400/90"
              >
                {t(lang, 'masseuses.bioTitle')}
              </h2>
              <p class="text-[15px] sm:text-base text-stone-200/95 leading-relaxed [text-wrap:pretty]">
                {pickLocale(lang, detail.personalIntro)}
              </p>
            </section>
          )
        }
        {
          detail && (
            <div class="grid gap-6 lg:grid-cols-2 lg:items-stretch">
              <section
                class:list={[softPanel, 'flex flex-col gap-4']}
                aria-labelledby="host-params-heading"
              >
                <h2
                  id="host-params-heading"
                  class="font-display text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.26em] text-cyan-400/90"
                >
                  {t(lang, 'masseuses.parametersTitle')}
                </h2>
                <a
                  href={`tel:${contact.phoneTel}`}
                  class="font-display text-sm font-semibold text-cyan-300 hover:text-cyan-100 transition-colors w-fit touch-manipulation min-h-10 inline-flex items-center"
                >
                  {contact.phoneDisplay}
                </a>
                {
                  detail.stats && (
                    <div class="pt-2 border-t border-white/[0.08]">
                      <MasseuseStatsBar lang={lang} stats={detail.stats} />
                    </div>
                  )
                }
              </section>
              <MasseuseServices services={detail.services} lang={lang} class={`${softPanel} h-full`} />
            </div>
          )
        }

        <div id="night-booking" class="scroll-mt-40 sm:scroll-mt-44 w-full">
          <div
            class="rounded-3xl border border-cyan-500/15 bg-gradient-to-b from-cyan-500/[0.04] via-black/30 to-black/40 p-1 shadow-[0_0_48px_-20px_rgba(0,240,255,0.18)] ring-1 ring-white/[0.04]"
          >
            <BookingForm lang={lang} defaultMasseuseSlug={slug} />
          </div>
        </div>

        <p class="text-center lg:text-start">
          <a
            href={masseusesIndexHref}
            class="inline-flex min-h-11 items-center text-xs text-stone-500 hover:text-cyan-400 font-display uppercase tracking-[0.15em] transition-colors touch-manipulation"
          >
            {t(lang, 'masseuses.back')}
          </a>
        </p>
      </div>
    </div>
  </div>

  {
    m && (
      <dialog
        class="host-profile-lightbox m-0 max-h-none max-w-none border-0 bg-transparent p-0 text-[0] backdrop:bg-void/92 backdrop:backdrop-blur-sm open:flex open:h-full open:w-full open:max-w-none open:items-center open:justify-center z-[100]"
        aria-labelledby="host-lightbox-title"
        data-host-lightbox-dialog
      >
        <div
          class="relative flex max-h-[min(92dvh,920px)] w-[min(96vw,1200px)] flex-col gap-3 p-3 sm:p-5"
          role="document"
        >
          <h2 id="host-lightbox-title" class="sr-only">
            {name} — {t(lang, 'masseuses.photoGallery')}
          </h2>
          <div class="absolute end-2 top-2 z-20 flex gap-2 sm:end-4 sm:top-4">
            <button
              type="button"
              class="rounded-lg border border-white/20 bg-black/70 px-3 py-2 font-display text-[10px] font-bold uppercase tracking-wider text-stone-200 backdrop-blur-md transition hover:border-cyan-500/50 hover:text-cyan-200 touch-manipulation min-h-11 min-w-11 sm:min-w-0"
              data-host-lightbox-close
              aria-label={t(lang, 'home.galleryClose')}
            >
              <span aria-hidden="true">✕</span>
            </button>
          </div>
          <div class="relative flex flex-1 items-center justify-center gap-2 sm:gap-3 min-h-0">
            <button
              type="button"
              class="hidden sm:flex shrink-0 rounded-lg border border-white/15 bg-black/50 p-2 text-cyan-300 backdrop-blur-sm transition hover:border-cyan-500/40 hover:bg-black/70 touch-manipulation min-h-11 min-w-11 items-center justify-center"
              data-host-lightbox-prev
              aria-label={t(lang, 'home.galleryPrev')}
            >
              <span class="text-lg leading-none" aria-hidden="true">
                ‹
              </span>
            </button>
            <div class="relative flex min-h-0 w-full flex-1 items-center justify-center overflow-hidden rounded-xl border border-white/10 bg-black/40 shadow-[0_0_60px_-20px_rgba(0,240,255,0.15)]">
              <img
                src=""
                alt=""
                class="max-h-[min(78dvh,800px)] max-w-full object-contain"
                data-host-lightbox-img
                decoding="async"
              />
            </div>
            <button
              type="button"
              class="hidden sm:flex shrink-0 rounded-lg border border-white/15 bg-black/50 p-2 text-cyan-300 backdrop-blur-sm transition hover:border-cyan-500/40 hover:bg-black/70 touch-manipulation min-h-11 min-w-11 items-center justify-center"
              data-host-lightbox-next
              aria-label={t(lang, 'home.galleryNext')}
            >
              <span class="text-lg leading-none" aria-hidden="true">
                ›
              </span>
            </button>
          </div>
          <p
            class="text-center font-display text-[10px] uppercase tracking-[0.2em] text-stone-500"
            data-host-lightbox-counter
            aria-live="polite"
          />
          <div class="flex justify-center gap-3 sm:hidden">
            <button
              type="button"
              class="rounded-lg border border-white/15 bg-black/50 px-4 py-2 font-display text-[10px] uppercase tracking-wider text-cyan-300 touch-manipulation min-h-11"
              data-host-lightbox-prev-m
              aria-label={t(lang, 'home.galleryPrev')}
            >
              ‹
            </button>
            <button
              type="button"
              class="rounded-lg border border-white/15 bg-black/50 px-4 py-2 font-display text-[10px] uppercase tracking-wider text-cyan-300 touch-manipulation min-h-11"
              data-host-lightbox-next-m
              aria-label={t(lang, 'home.galleryNext')}
            >
              ›
            </button>
          </div>
        </div>
      </dialog>
    )
  }

  <div
    class="fixed bottom-0 inset-x-0 z-30 md:hidden flex gap-2 p-3 border-t border-white/[0.08] bg-void/92 backdrop-blur-xl pb-[max(0.75rem,env(safe-area-inset-bottom))]"
    style="padding-left: max(0.75rem, env(safe-area-inset-left)); padding-right: max(0.75rem, env(safe-area-inset-right));"
  >
    <a
      href={`tel:${contact.phoneTel}`}
      class="btn-neon-ghost flex-1 justify-center min-h-12 text-xs touch-manipulation border-white/15"
    >
      {t(lang, 'masseuses.ctaCall')}
    </a>
    <a href={bookHref} class="btn-neon-primary flex-[1.35] justify-center min-h-12 text-xs touch-manipulation">
      {t(lang, 'masseuses.ctaStickyBook')}
    </a>
  </div>
</article>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-host-profile-gallery]');
    var main = document.getElementById('host-main-photo');
    if (!main) return;

    var urls = [];
    var counterTpl = '{current} / {total}';
    var lightboxLabel = '';
    if (root) {
      try {
        urls = JSON.parse(root.getAttribute('data-host-gallery-urls') || '[]');
      } catch (e) {}
      counterTpl = root.getAttribute('data-host-gallery-counter-tpl') || counterTpl;
      lightboxLabel = root.getAttribute('data-host-gallery-lightbox-label') || '';
    }

    var dialog = document.querySelector('[data-host-lightbox-dialog]');
    var lbImg = document.querySelector('[data-host-lightbox-img]');
    var lbCounter = document.querySelector('[data-host-lightbox-counter]');
    var lbClose = document.querySelector('[data-host-lightbox-close]');
    var lbPrev = document.querySelector('[data-host-lightbox-prev]');
    var lbNext = document.querySelector('[data-host-lightbox-next]');
    var lbPrevM = document.querySelector('[data-host-lightbox-prev-m]');
    var lbNextM = document.querySelector('[data-host-lightbox-next-m]');

    var index = 0;

    function indexForSrc(src) {
      if (!src || !urls.length) return 0;
      var i = urls.indexOf(src);
      if (i >= 0) return i;
      for (var j = 0; j < urls.length; j++) {
        if (src.indexOf(urls[j]) !== -1 || src.endsWith(urls[j])) return j;
      }
      return 0;
    }

    function formatCounter(i) {
      return counterTpl.replace('{current}', String(i + 1)).replace('{total}', String(urls.length));
    }

    function showLightbox(i) {
      if (!lbImg || !urls.length) return;
      index = ((i % urls.length) + urls.length) % urls.length;
      lbImg.src = urls[index] || '';
      lbImg.alt = lightboxLabel ? lightboxLabel + ' ' + (index + 1) : '';
      if (lbCounter) lbCounter.textContent = formatCounter(index);
    }

    function openLightbox(i) {
      if (!dialog || typeof dialog.showModal !== 'function' || !urls.length) return;
      showLightbox(i);
      dialog.showModal();
    }

    if (dialog && lbImg) {
      dialog.addEventListener('close', function () {
        lbImg.removeAttribute('src');
      });
      dialog.addEventListener('click', function (e) {
        if (e.target === dialog) dialog.close();
      });
      if (lbClose) lbClose.addEventListener('click', function () { dialog.close(); });
      if (lbPrev) lbPrev.addEventListener('click', function () { showLightbox(index - 1); });
      if (lbNext) lbNext.addEventListener('click', function () { showLightbox(index + 1); });
      if (lbPrevM) lbPrevM.addEventListener('click', function () { showLightbox(index - 1); });
      if (lbNextM) lbNextM.addEventListener('click', function () { showLightbox(index + 1); });
      document.addEventListener('keydown', function (e) {
        if (!dialog.open) return;
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          showLightbox(index - 1);
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          showLightbox(index + 1);
        }
      });
    }

    function syncThumbActive(btn) {
      document.querySelectorAll('[data-host-thumb]').forEach(function (b) {
        b.removeAttribute('data-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.setAttribute('data-active', '');
      btn.setAttribute('aria-pressed', 'true');
    }

    document.querySelectorAll('[data-host-thumb]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var src = btn.getAttribute('data-src');
        if (!src) return;
        main.src = src;
        syncThumbActive(btn);
        var gi = btn.getAttribute('data-gallery-index');
        var i = gi != null ? parseInt(gi, 10) : indexForSrc(src);
        if (!isNaN(i) && urls.length) openLightbox(i);
      });
    });

    var mainOpen = document.getElementById('host-main-photo-open');
    if (mainOpen && urls.length) {
      mainOpen.addEventListener('click', function () {
        openLightbox(indexForSrc(main.getAttribute('src') || main.src));
      });
    }
  })();
</script>
