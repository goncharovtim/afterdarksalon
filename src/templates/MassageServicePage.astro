---
import WpContent from '../components/WpContent.astro';
import PriceBlockTabs from '../components/PriceBlockTabs.astro';
import { massageGrid } from '../data/site';
import { getMasseusesForService } from '../data/catalog/adapters';
import { getSalonPriceBlock } from '../data/pricing';
import type { Lang } from '../i18n/types';
import { t } from '../i18n/t';
import { massageTitle } from '../i18n/massages';
import { pathMassage, pathMasseuse, pathMasseuses, pathPrice } from '../i18n/paths';

type GridItem = (typeof massageGrid)[number];

type Props = {
  lang: Lang;
  slug: string;
  item: GridItem | undefined;
  page: { title: string; html: string } | null;
  bookHref: string;
  massagesIndexHref: string;
};

const { lang, slug, item, page, bookHref, massagesIndexHref } = Astro.props;

const label = item ? massageTitle(lang, item.slug) : slug;
const heading = page?.title ?? label;
const related = massageGrid.filter((m) => m.slug !== slug);
const salonBlock = getSalonPriceBlock(lang);
const hostsForMassage = getMasseusesForService(slug);
---

<article class="pb-24 md:pb-0">
  <header class="relative isolate overflow-hidden">
    {
      item && (
        <>
          <div class="absolute inset-0 z-0">
            <img
              src={item.image}
              alt=""
              width="1200"
              height="800"
              class="h-full w-full object-cover object-center scale-105 sm:scale-100"
              loading="eager"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-void via-void/85 to-void/50 sm:via-abyss/90 sm:to-abyss/40"
              aria-hidden="true"
            />
            <div
              class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_120%,rgba(255,45,106,0.25),transparent)]"
              aria-hidden="true"
            />
          </div>
        </>
      )
    }

    <div
      class:list={[
        'relative z-10 mx-auto flex min-h-[30dvh] max-w-7xl flex-col justify-end px-[max(1rem,env(safe-area-inset-left,0px))] pb-5 pe-[max(1rem,env(safe-area-inset-right,0px))] pt-16 sm:min-h-[16rem] sm:px-5 sm:pt-20 md:min-h-[18rem] lg:min-h-[20rem]',
        !item && 'bg-surface/40 border-b border-cyan-500/15 min-h-[auto] py-6 pt-14',
      ]}
    >
      <nav class="mb-2 sm:mb-3 font-display text-[10px] sm:text-xs uppercase tracking-[0.2em] text-stone-500" aria-label="Breadcrumb">
        <a href={massagesIndexHref} class="hover:text-cyan-400 transition-colors">{t(lang, 'nav.services')}</a>
        <span class="mx-2 text-stone-700" aria-hidden="true">/</span>
        <span class="text-fuchsia-400/90">{heading}</span>
      </nav>
      <p class="font-display text-[10px] sm:text-xs font-bold uppercase tracking-[0.35em] text-cyan-400 mb-1.5">
        {t(lang, 'massages.detailEyebrow')}
      </p>
      <h1
        class="font-display text-3xl sm:text-4xl lg:text-5xl font-black uppercase tracking-tight text-white drop-shadow-[0_2px_24px_rgba(0,0,0,0.8)] max-w-4xl"
      >
        {heading}
      </h1>
      <p class="mt-2 max-w-2xl text-sm sm:text-base text-stone-300/95 leading-relaxed">
        {t(lang, 'massages.trustLine')}
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-4">
        <a
          href="#massage-reserve"
          class="sm:hidden inline-flex btn-neon-primary min-h-12 px-6 text-xs touch-manipulation"
        >
          {t(lang, 'massages.bookRitual')}
        </a>
        <a href={massagesIndexHref} class="btn-neon-ghost min-h-12 text-xs sm:text-sm touch-manipulation">
          {t(lang, 'massages.back')}
        </a>
      </div>
    </div>
  </header>

  <div
    class="page-content space-y-5 px-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] sm:space-y-6 sm:px-5"
  >
    <section
      class="rounded-2xl border border-white/[0.08] bg-surface/60 backdrop-blur-md shadow-[0_24px_80px_rgba(0,0,0,0.35)] overflow-hidden"
      aria-labelledby="massage-experience-heading"
    >
      <div class="px-1 pt-1">
        <div class="rounded-xl bg-gradient-to-r from-cyan-500/15 via-fuchsia-500/10 to-transparent px-4 py-2.5 sm:px-5 border-b border-white/5">
          <h2
            id="massage-experience-heading"
            class="font-display text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-cyan-300/90"
          >
            {t(lang, 'massages.experienceTitle')}
          </h2>
        </div>
      </div>
      <div class="p-4 sm:p-5 md:p-6">
        {
          page ? (
            <WpContent
              html={page.html}
              class="prose-wp prose-wp--detail max-w-none lg:max-w-4xl lg:mx-auto"
            />
          ) : (
            <p class="text-center text-stone-500 py-8">{t(lang, 'massages.pageLoadError')}</p>
          )
        }
      </div>
    </section>

    {
      hostsForMassage.length > 0 && (
        <section
          class="rounded-2xl border border-white/[0.08] bg-surface/40 backdrop-blur-md shadow-[0_16px_48px_rgba(0,0,0,0.28)] overflow-hidden"
          aria-labelledby="massage-hosts-heading"
        >
          <div class="px-1 pt-1">
            <div class="rounded-xl bg-gradient-to-r from-fuchsia-500/12 via-cyan-500/10 to-transparent px-4 py-2.5 sm:px-5 border-b border-white/5">
              <h2
                id="massage-hosts-heading"
                class="font-display text-xs sm:text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-300/90"
              >
                {t(lang, 'massages.whoOffersTitle')}
              </h2>
            </div>
          </div>
          <div class="p-2 sm:p-3 md:p-4">
            <ul
              class="flex flex-wrap justify-center gap-1.5 sm:gap-2 list-none p-0 m-0"
              role="list"
            >
              {hostsForMassage.map((h) => (
                <li class="shrink-0 w-[4rem] sm:w-[4.25rem]">
                  <a
                    href={pathMasseuse(lang, h.slug)}
                    class="group flex flex-col overflow-hidden rounded-md border border-white/10 bg-black/30 shadow-[0_4px_14px_rgba(0,0,0,0.35)] transition-all hover:border-cyan-500/40 hover:shadow-[0_6px_18px_rgba(0,240,255,0.06)] touch-manipulation min-h-0"
                    aria-label={`${h.name} - ${t(lang, 'massages.hostProfileHint')}`}
                  >
                    <div class="relative aspect-[7/9] overflow-hidden bg-black shrink-0">
                      {h.cardImageScale != null && h.cardImageScale > 1 ? (
                        <div class="absolute inset-0 overflow-hidden">
                          <div
                            class="host-card-photo-zoom size-full"
                            style={{
                              '--host-card-zoom': String(h.cardImageScale),
                              '--host-zoom-origin': h.cardImageObjectPosition ?? 'center center',
                            }}
                          >
                            <img
                              src={h.image}
                              alt=""
                              width="96"
                              height="124"
                              class:list={[
                                'size-full object-cover opacity-90 transition-opacity duration-500 group-hover:opacity-100',
                                !h.cardImageObjectPosition && 'object-top',
                              ]}
                              style={
                                h.cardImageObjectPosition ? { objectPosition: h.cardImageObjectPosition } : undefined
                              }
                              loading="lazy"
                              decoding="async"
                            />
                          </div>
                        </div>
                      ) : (
                        <img
                          src={h.image}
                          alt=""
                          width="96"
                          height="124"
                          class:list={[
                            'size-full object-cover opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100',
                            !h.cardImageObjectPosition && 'object-top',
                          ]}
                          style={h.cardImageObjectPosition ? { objectPosition: h.cardImageObjectPosition } : undefined}
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-void/90 via-transparent to-transparent opacity-80 pointer-events-none" />
                    </div>
                    <div class="px-1 py-1 sm:px-1.5 sm:py-1.5 border-t border-white/5">
                      <span class="font-display text-[7px] sm:text-[8px] font-bold uppercase tracking-[0.08em] text-white group-hover:text-cyan-200 transition-colors leading-tight line-clamp-2">
                        {h.name}
                      </span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-2 sm:mt-3 text-center">
              <a
                href={pathMasseuses(lang)}
                class="inline-flex text-[9px] font-display uppercase tracking-wider text-stone-500 hover:text-cyan-400 transition-colors touch-manipulation min-h-8 items-center"
              >
                {t(lang, 'nav.hosts')} →
              </a>
            </p>
          </div>
        </section>
      )
    }

    <div class="space-y-3">
      <p class="font-display text-[10px] font-bold uppercase tracking-[0.3em] text-cyan-500/80">
        {t(lang, 'price.eyebrow')}
      </p>
      <div class="grid gap-5 lg:grid-cols-12 lg:gap-8 items-start">
        <aside class="lg:col-span-4 order-2 lg:order-1 lg:sticky lg:top-[8.5rem] xl:top-[9rem] self-start">
          <div class="card-cyber neon-border p-4 sm:p-5 h-full">
            <ul class="space-y-2 text-sm text-stone-300 leading-snug">
              <li class="flex gap-2">
                <span class="text-cyan-400 shrink-0" aria-hidden="true">◇</span>
                <span>{t(lang, 'schedule.subtitle')}</span>
              </li>
              <li class="flex gap-2">
                <span class="text-fuchsia-400 shrink-0" aria-hidden="true">◇</span>
                <span>{t(lang, 'footer.nightAccessBody')}</span>
              </li>
              <li class="flex gap-2">
                <span class="text-amber-400 shrink-0" aria-hidden="true">◇</span>
                <span>{t(lang, 'header.prague1')}</span>
              </li>
            </ul>
            <a
              href={pathPrice(lang)}
              class="mt-5 inline-flex w-full justify-center min-h-11 rounded-lg border border-cyan-500/35 px-4 py-2.5 text-[10px] font-display font-semibold uppercase tracking-wider text-cyan-300 hover:border-fuchsia-500/40 hover:text-fuchsia-200 transition-colors touch-manipulation"
            >
              {t(lang, 'massages.viewFullPriceList')}
            </a>
          </div>
        </aside>

        <div class="lg:col-span-8 order-1 lg:order-2 min-w-0">
          <PriceBlockTabs block={salonBlock} index={0} lang={lang} />
        </div>
      </div>
    </div>

    {
      related.length > 0 && (
        <section class="mt-8 sm:mt-12 border-t border-white/10 pt-8 sm:pt-10" aria-labelledby="related-massages-heading">
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
            <h2
              id="related-massages-heading"
              class="font-display text-lg sm:text-xl font-bold uppercase tracking-[0.12em] text-gradient-neon"
            >
              {t(lang, 'massages.relatedTitle')}
            </h2>
            <a
              href={massagesIndexHref}
              class="text-xs font-display uppercase tracking-wider text-cyan-400/90 hover:text-fuchsia-400 shrink-0 touch-manipulation min-h-11 inline-flex items-center"
            >
              {t(lang, 'massages.back')}
            </a>
          </div>
          <div
            class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible snap-x snap-mandatory sm:snap-none scrollbar-cyber"
          >
            {related.map((m) => (
              <a
                href={pathMassage(lang, m.slug)}
                class="group shrink-0 w-[min(78vw,17rem)] sm:w-auto snap-center card-cyber overflow-hidden flex flex-col border border-white/10 hover:border-cyan-500/40 transition-all touch-manipulation"
              >
                <div class="relative aspect-[4/3] overflow-hidden bg-black">
                  <img
                    src={m.image}
                    alt=""
                    width="320"
                    height="240"
                    class="size-full object-cover opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-void via-transparent to-transparent opacity-90" />
                  <p class="absolute bottom-2 left-2 right-2 font-display text-xs font-bold uppercase tracking-wide text-white">
                    {massageTitle(lang, m.slug)}
                  </p>
                </div>
                <span class="px-3 py-3 text-[10px] font-display uppercase tracking-wider text-cyan-400/80 group-hover:text-fuchsia-300">
                  {t(lang, 'massages.intel')} →
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section
      id="massage-reserve"
      class="mt-8 sm:mt-10 scroll-mt-[calc(8rem+0.75rem)] md:scroll-mt-[calc(8.75rem+0.75rem)] rounded-2xl border border-fuchsia-500/25 bg-gradient-to-br from-fuchsia-950/30 via-black/40 to-cyan-950/20 p-5 sm:p-7 text-center shadow-[0_24px_64px_rgba(0,0,0,0.45)]"
      aria-labelledby="massage-reserve-heading"
    >
      <h2
        id="massage-reserve-heading"
        class="font-display text-lg sm:text-xl font-bold uppercase tracking-[0.12em] text-gradient-neon mb-2"
      >
        {t(lang, 'massages.reserveSectionTitle')}
      </h2>
      <p class="text-sm text-stone-400 max-w-lg mx-auto mb-6 leading-relaxed">
        {t(lang, 'massages.reserveSectionLead')}
      </p>
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch justify-center gap-3">
        <a href={bookHref} class="btn-neon-primary min-h-12 px-8 justify-center touch-manipulation">
          {t(lang, 'massages.bookRitual')}
        </a>
        <a href={pathPrice(lang)} class="btn-neon-ghost min-h-12 justify-center touch-manipulation">
          {t(lang, 'massages.viewFullPriceList')}
        </a>
      </div>
    </section>
  </div>

  <div
    class="fixed bottom-0 inset-x-0 z-30 md:hidden flex gap-2 p-3 border-t border-cyan-500/20 bg-void/95 backdrop-blur-lg supports-[backdrop-filter]:bg-void/80 pb-[max(0.75rem,env(safe-area-inset-bottom))]"
    style="padding-left: max(0.75rem, env(safe-area-inset-left)); padding-right: max(0.75rem, env(safe-area-inset-right));"
  >
    <a href={bookHref} class="btn-neon-primary flex-1 justify-center min-h-12 text-xs touch-manipulation">
      {t(lang, 'massages.ctaStickyBook')}
    </a>
    <a href={massagesIndexHref} class="btn-neon-ghost flex-1 justify-center min-h-12 text-xs touch-manipulation">
      {t(lang, 'massages.ctaStickyMore')}
    </a>
  </div>
</article>
