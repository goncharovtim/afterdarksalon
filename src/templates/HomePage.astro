---
import type { Lang } from '../i18n/types';
import { pickLocale } from '../i18n/locale';
import { t, tArr } from '../i18n/t';
import { pathBook, pathMassage, pathMasseuse, pathMasseuses, pathPrice } from '../i18n/paths';
import { massageTitle } from '../i18n/massages';
import { homeCta, homeHero, featuredMasseuses, massageGrid } from '../data/site';
import { SALON_GALLERY_ITEMS } from '../data/salonGallery';
import SalonGallery from '../components/SalonGallery.astro';
import { getMasseuseDetail } from '../data/masseuseDetails';
import MasseuseCardImage from '../components/MasseuseCardImage.astro';
import GoogleRatingBanner from '../components/GoogleRatingBanner.astro';

type Props = { lang: Lang };

const { lang } = Astro.props;
const intro = tArr(lang, 'home.intro');
const ctaPs = [t(lang, 'home.ctaP1'), t(lang, 'home.ctaP2'), t(lang, 'home.ctaP3')];
const homeMassageTiles = massageGrid.filter((item) => item.homeFeature !== false);
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-center opacity-35"
    style={`background-image: url(${homeHero.background})`}
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-void via-abyss/95 to-void" aria-hidden="true"></div>
  <div class="absolute inset-0 cyber-grid-bg opacity-50 pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[120%] max-w-4xl h-64 bg-fuchsia-600/10 blur-[100px] rounded-full pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto w-full max-w-7xl px-[max(1rem,env(safe-area-inset-left,0px))] pb-14 pe-[max(1rem,env(safe-area-inset-right,0px))] pt-6 sm:px-4 sm:pt-7 sm:pb-16 md:pt-8 md:pb-20"
  >
    <div class="max-w-4xl mx-auto text-center space-y-7 md:space-y-8">
      <p
        class="font-display text-[10px] sm:text-xs font-bold uppercase tracking-[0.4em] text-cyan-400 glow-pulse inline-block"
      >
        {t(lang, 'home.tagline')}
      </p>
      <h1
        class="font-display flex flex-col items-center gap-2 font-black uppercase leading-[1.1] tracking-tight animate-float md:gap-3"
      >
        <span
          class="block min-w-0 max-w-full text-center whitespace-nowrap text-gradient-neon text-[clamp(0.7rem,3.85vw,2.625rem)] sm:text-[clamp(0.8rem,3.15vw,3rem)] md:text-[clamp(0.95rem,2.65vw,3.75rem)] lg:text-[clamp(1.05rem,2.35vw,4.25rem)]"
        >
          {t(lang, 'home.heroTitle')}
        </span>
        <span
          class="block text-center whitespace-nowrap text-gradient-neon text-3xl sm:text-4xl md:text-6xl"
        >
          {t(lang, 'home.heroTitleBrand')}
        </span>
      </h1>
      <div class="space-y-4 text-sm md:text-base text-stone-400 leading-relaxed max-w-2xl mx-auto px-1 sm:px-0">
        {intro.map((line) => (
          <p>{line}</p>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch justify-center gap-5 pt-5 sm:gap-4 sm:pt-6 md:pt-8">
        <a
          href={pathBook(lang)}
          class="btn-neon-primary min-h-12 flex-1 min-w-0 justify-center text-center sm:flex-[1_1_0]"
        >
          {t(lang, 'home.reserveNight')}
        </a>
        <a
          href={pathMasseuses(lang)}
          class="btn-neon-ghost min-h-12 flex-1 min-w-0 justify-center text-center !px-6 !py-3 !text-sm !font-semibold !tracking-widest sm:flex-[1_1_0]"
        >
          {t(lang, 'home.browseHosts')}
        </a>
      </div>
    </div>
  </div>
</section>

<section class="py-12 md:py-16 ps-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12 space-y-4 md:mb-16 md:space-y-5">
      <h2 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-[0.15em] text-gradient-neon">
        {t(lang, 'home.teamTitle')}
      </h2>
      <p class="font-display text-sm text-fuchsia-400/90 uppercase tracking-widest">
        {t(lang, 'home.teamHours')}
      </p>
      <p class="text-stone-500 max-w-2xl mx-auto">{t(lang, 'home.teamBlurb')}</p>
    </div>
    <div class="grid gap-7 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {featuredMasseuses.map((m) => {
        const d = getMasseuseDetail(m.slug);
        return (
          <div class="host-card-neon-shell h-full min-w-0">
            <a
              href={pathMasseuse(lang, m.slug)}
              class="card-cyber group flex h-full min-h-0 flex-col overflow-hidden"
            >
            <div class="relative aspect-[7/10] overflow-hidden bg-black">
              <MasseuseCardImage
                lang={lang}
                name={m.name}
                image={m.image}
                imageObjectPosition={m.cardImageObjectPosition}
                imageScale={m.cardImageScale}
                vibe={d ? pickLocale(lang, d.vibe) : undefined}
                stats={d?.stats}
                compact
              />
            </div>
            <div class="flex flex-wrap gap-2 p-4 border-t border-white/5">
              {d?.services.slice(0, 3).map((s) => (
                <span class="inline-flex min-h-7 items-center justify-center rounded border border-white/10 px-2.5 text-center font-display text-[10px] uppercase leading-none tracking-wider text-stone-500">
                  {massageTitle(lang, s.slug)}
                </span>
              ))}
            </div>
            <div class="px-4 pb-4 flex gap-2">
              <span class="btn-neon-ghost !py-1.5 !text-[9px] flex-1 justify-center pointer-events-none">
                {t(lang, 'home.cardProfile')}
              </span>
              <span class="inline-flex flex-1 items-center justify-center rounded border border-cyan-500/30 text-[9px] font-display uppercase tracking-wider text-cyan-300 pointer-events-none">
                {t(lang, 'home.cardBook')}
              </span>
            </div>
          </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<section class="py-12 md:py-16 ps-[max(1rem,env(safe-area-inset-left,0px))] pe-[max(1rem,env(safe-area-inset-right,0px))] border-t border-cyan-500/10 bg-black/20">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-display text-center text-xl md:text-2xl font-bold uppercase tracking-[0.2em] text-cyan-300 mb-11 md:mb-14">
      {t(lang, 'home.protocolsTitle')}
    </h2>
    <div class="grid gap-5 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3">
      {homeMassageTiles.map((item) => (
        <a
          href={pathMassage(lang, item.slug)}
          class="group flex min-h-[4.5rem] items-center gap-4 rounded-xl border border-white/10 bg-surface/40 p-4 transition-all hover:border-fuchsia-500/35 touch-manipulation"
        >
          <div class="size-16 shrink-0 rounded-lg overflow-hidden border border-cyan-500/20">
            <img src={item.image} alt="" class="size-full object-cover group-hover:scale-110 transition-transform" loading="lazy" />
          </div>
          <div>
            <h3 class="font-display text-sm font-bold text-white uppercase tracking-wide group-hover:text-fuchsia-300 transition-colors">
              {massageTitle(lang, item.slug)}
            </h3>
            <p class="text-[10px] text-stone-600 uppercase tracking-widest mt-1">{t(lang, 'home.openDossier')}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="py-10 md:py-12 px-4 border-t border-cyan-500/10 bg-black/15">
  <div class="max-w-7xl mx-auto flex justify-center">
    <GoogleRatingBanner lang={lang} variant="footer" />
  </div>
</section>

<SalonGallery lang={lang} items={SALON_GALLERY_ITEMS} />

<section class="relative py-14 md:py-20 px-4 overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-center opacity-25"
    style={`background-image: url(${homeCta.background})`}
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-gradient-to-t from-void via-abyss/95 to-void" aria-hidden="true"></div>
  <div class="relative max-w-4xl mx-auto text-center space-y-9 md:space-y-10">
    <h2 class="font-display text-2xl md:text-4xl font-bold uppercase tracking-tight text-gradient-neon">
      {t(lang, 'home.ctaTitle')}
    </h2>
    <div class="space-y-6 text-stone-400 text-sm md:text-base leading-relaxed font-medium md:space-y-5">
      {ctaPs.map((p) => (
        <p>{p}</p>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-4 pt-2 max-sm:flex-col max-sm:items-stretch max-sm:gap-5 sm:pt-0">
      <a href={pathBook(lang)} class="btn-neon-primary">{t(lang, 'home.ctaQueue')}</a>
      <a href={pathPrice(lang)} class="btn-neon-ghost">{t(lang, 'home.ctaPrice')}</a>
    </div>
  </div>
</section>
